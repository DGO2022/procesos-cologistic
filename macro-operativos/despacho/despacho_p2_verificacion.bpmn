<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_1"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  exporter="Camunda Modeler"
                  exporterVersion="5.22.0"
                  modeler:executionPlatform="Camunda Cloud"
                  modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Procedimiento Verificación y conformidad" processRef="Process_Despacho_Verificacion" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Despacho_Verificacion" isExecutable="true">
    <bpmn:documentation>Co Logistic SAC — Proceso: Despacho de mercadería
Procedimiento 2: Verificación y conformidad
Fuente: 2-Despacho.txt (fragmento "Lo demás es el mismo proceso. Si hay que modificar, se modifica... se despacha el sistema igual."), 10-Explicacion_de_reporte-adjuntar-a-guia.txt
Elementos BPMN representados:
  - Tarea de recepción (Receive Task, continúa de P1)
  - Tareas (Task)
  - Compuerta exclusiva (Exclusive Gateway / XOR) de conformidad
  - Artefacto de datos / Data Object (pedido de salida + guía engrampados)
  - Evento de fin (End Event)
  - Pools/Lanes: Auxiliar de almacén, Supervisor
Nota: misma estructura que Recepción P2; cambia únicamente la nomenclatura del documento (pedido de salida / P.S. en vez de pedido de ingreso)</bpmn:documentation>

    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Auxiliar_Almacen" name="Auxiliar de almacén">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Supervisor" name="Supervisor">
        <bpmn:flowNodeRef>Gateway_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_1" name="Recibe pedido de salida (de P1)">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_1" name="Verificar mercadería contra pedido de salida">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_1" name="¿Conforme a la guía?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3_si</bpmn:outgoing>
      <bpmn:outgoing>Flow_4_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_2" name="Aprobar pedido y despachar">
      <bpmn:incoming>Flow_3_si</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_3" name="Modificar pedido: cantidad, lote, FV, zona/ubicación o reempaque">
      <bpmn:incoming>Flow_4_no</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_4" name="Imprimir y engrampar P.S. + guía de remisión">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1">
        <bpmn:targetRef>DataObjectReference_1</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>

    <bpmn:dataObjectReference id="DataObjectReference_1" name="Pedido de salida (P.S.) + guía de remisión (archivado)" dataObjectRef="DataObject_1" />
    <bpmn:dataObject id="DataObject_1" />

    <bpmn:endEvent id="EndEvent_1" name="Fin">
      <bpmn:incoming>Flow_7</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Gateway_1" />
    <bpmn:sequenceFlow id="Flow_3_si" name="sí" sourceRef="Gateway_1" targetRef="Task_2" />
    <bpmn:sequenceFlow id="Flow_4_no" name="no" sourceRef="Gateway_1" targetRef="Task_3" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_2" targetRef="Task_4" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_3" targetRef="Task_4" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_4" targetRef="EndEvent_1" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_1_di" bpmnElement="Participant_1" isHorizontal="true">
        <dc:Bounds x="130" y="80" width="1030" height="450" />
      </bpmndi:BPMNShape>
      <!-- Layout for Lane -->
      <bpmndi:BPMNShape id="Lane_Auxiliar_Almacen_di" bpmnElement="Lane_Auxiliar_Almacen" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1000" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Supervisor_di" bpmnElement="Lane_Supervisor" isHorizontal="true">
        <dc:Bounds x="160" y="280" width="1000" height="250" />
      </bpmndi:BPMNShape>
      
      <!-- Nodes layout -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="212" y="152" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_1_di" bpmnElement="Task_1">
        <dc:Bounds x="320" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_1_di" bpmnElement="Gateway_1" isMarkerVisible="true">
        <dc:Bounds x="485" y="375" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_2_di" bpmnElement="Task_2">
        <dc:Bounds x="600" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_3_di" bpmnElement="Task_3">
        <dc:Bounds x="600" y="420" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_4_di" bpmnElement="Task_4">
        <dc:Bounds x="760" y="360" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="DataObjectReference_1_di" bpmnElement="DataObjectReference_1">
        <dc:Bounds x="792" y="480" width="36" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="922" y="382" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Edges Layout -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="248" y="170" />
        <di:waypoint x="320" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="420" y="170" />
        <di:waypoint x="450" y="170" />
        <di:waypoint x="450" y="400" />
        <di:waypoint x="485" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_si_di" bpmnElement="Flow_3_si">
        <di:waypoint x="510" y="375" />
        <di:waypoint x="510" y="340" />
        <di:waypoint x="600" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_no_di" bpmnElement="Flow_4_no">
        <di:waypoint x="510" y="425" />
        <di:waypoint x="510" y="460" />
        <di:waypoint x="600" y="460" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="700" y="340" />
        <di:waypoint x="730" y="340" />
        <di:waypoint x="730" y="400" />
        <di:waypoint x="760" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="700" y="460" />
        <di:waypoint x="730" y="460" />
        <di:waypoint x="730" y="400" />
        <di:waypoint x="760" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="860" y="400" />
        <di:waypoint x="922" y="400" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="DataOutputAssociation_1_di" bpmnElement="DataOutputAssociation_1">
        <di:waypoint x="810" y="440" />
        <di:waypoint x="810" y="480" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
