<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions 
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" 
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" 
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.22.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Procedimiento Registro de pedido de salida" processRef="Process_Despacho_Registro" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Despacho_Registro" isExecutable="true">
    <bpmn:documentation>Co Logistic SAC — Proceso: Despacho de mercadería
Procedimiento 1: Registro de pedido de salida (con lógica FEFO)
Fuente: 2-Despacho.txt, 6-Merchandising.txt, 7-GuiaCliente-Despacho.txt, 11-Explicacion_de_reporte-detalle.txt
Elementos BPMN representados:
  - Evento de inicio (Start Event)
  - Tareas (Task)
  - Compuerta exclusiva (Exclusive Gateway / XOR) de unidad comercial
  - Artefactos de datos / Data Objects (guía de remisión, zona/stock por lote)
  - Pools/Lanes: Cliente, Analista de inventarios
Nota: hereda la misma bifurcación caja/unidad que Recepción P1, y agrega la consulta de zona, stock y lote/FV (FEFO) propia del despacho.</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Cliente" name="Cliente">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Auxiliar" name="Auxiliar de almacén">
        <bpmn:flowNodeRef>Task_2b</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Analista_Inventarios" name="Analista de inventarios">
        <bpmn:flowNodeRef>Task_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_7</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_006qk4f</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_084ffmx</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_6</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="Inicio">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_1" name="Enviar guía de remisión">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1">
        <bpmn:targetRef>DataObjectReference_1</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_2b" name="Realizar picking">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2b" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2b" targetRef="Task_2" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_5" targetRef="Gateway_006qk4f" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_6" targetRef="Gateway_006qk4f" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_7" targetRef="EndEvent_1" />
    <bpmn:task id="Task_2" name="Registrar pedido de salida">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:property id="Property_02z9i4g" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_1">
        <bpmn:sourceRef>DataObjectReference_1</bpmn:sourceRef>
        <bpmn:targetRef>Property_02z9i4g</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_3" name="Consultar zona y stock">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_2">
        <bpmn:targetRef>DataObjectReference_2</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_2" name="¿Varias fechas de vencimiento?">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6_si</bpmn:outgoing>
      <bpmn:outgoing>Flow_7_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_2" targetRef="Task_3" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_3" targetRef="Gateway_2" />
    <bpmn:sequenceFlow id="Flow_6_si" name="sí" sourceRef="Gateway_2" targetRef="Task_4" />
    <bpmn:sequenceFlow id="Flow_7_no" name="no" sourceRef="Gateway_2" targetRef="Gateway_1" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_4" targetRef="Gateway_1" />
    <bpmn:task id="Task_7" name="Firmar pedido de salida">
      <bpmn:incoming>Flow_1n0bv90</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_1" name="Fin Procedimiento 1 (continúa en P2: Verificación)">
      <bpmn:incoming>Flow_13</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_006qk4f">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_1n0bv90</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1n0bv90" sourceRef="Gateway_006qk4f" targetRef="Task_7" />
    <bpmn:sequenceFlow id="Flow_1f3tx0i" sourceRef="Gateway_1" targetRef="Gateway_084ffmx" />
    <bpmn:exclusiveGateway id="Gateway_084ffmx" name="¿Unidad comercial del código?">
      <bpmn:incoming>Flow_1f3tx0i</bpmn:incoming>
      <bpmn:outgoing>Flow_17bccnu</bpmn:outgoing>
      <bpmn:outgoing>Flow_0fytdg7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_17bccnu" name="caja" sourceRef="Gateway_084ffmx" targetRef="Task_5" />
    <bpmn:sequenceFlow id="Flow_0fytdg7" name="unidad" sourceRef="Gateway_084ffmx" targetRef="Task_6" />
    <bpmn:exclusiveGateway id="Gateway_1">
      <bpmn:incoming>Flow_7_no</bpmn:incoming>
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_1f3tx0i</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_4" name="Seleccionar lote y fecha de vencimiento">
      <bpmn:incoming>Flow_6_si</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
      <bpmn:property id="Property_1hd78jx" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_2">
        <bpmn:sourceRef>DataObjectReference_2</bpmn:sourceRef>
        <bpmn:targetRef>Property_1hd78jx</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:task>
    <bpmn:dataObjectReference id="DataObjectReference_2" name="Stock y lote por código" dataObjectRef="DataObject_2" />
    <bpmn:dataObject id="DataObject_2" />
    <bpmn:task id="Task_5" name="Registrar pallets y cajas">
      <bpmn:incoming>Flow_17bccnu</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_6" name="Registrar unidades de merchandising">
      <bpmn:incoming>Flow_0fytdg7</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:dataObjectReference id="DataObjectReference_1" name="Guía de remisión" dataObjectRef="DataObject_1" />
    <bpmn:dataObject id="DataObject_1" />
  </bpmn:process>
