<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.22.0" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Procedimiento Registro de pedido de ingreso" processRef="Process_Recepcion_Registro" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Recepcion_Registro" isExecutable="true">
    <bpmn:documentation>Co Logistic SAC — Proceso: Recepción de mercadería
Procedimiento 1: Registro de pedido de ingreso
Fuente: 1-Recepcion.txt, 6-Merchandising.txt, 7-GuiaCliente-Despacho.txt, 8-Explicacion-paleta.txt, 10-Explicacion_de_reporte-adjuntar-a-guia.txt
Elementos BPMN representados:
  - Evento de inicio (Start Event)
  - Tareas (Task)
  - Compuerta exclusiva (Exclusive Gateway / XOR)
  - Artefacto de datos / Data Object (guía de remisión)
  - Pools/Lanes: Cliente, Analista de inventarios</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Analista_Inventarios" name="Analista de inventarios">
        <bpmn:flowNodeRef>Task_4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1ki3svm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_3</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Cliente" name="Cliente">
        <bpmn:flowNodeRef>Task_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:task id="Task_1" name="Enviar guía de remisión (correo, físico o WhatsApp)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1">
        <bpmn:targetRef>DataObjectReference_1</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:startEvent id="StartEvent_1" name="Inicio">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:dataObjectReference id="DataObjectReference_1" name="Guía de remisión (artefacto de datos)" dataObjectRef="DataObject_1" />
    <bpmn:dataObject id="DataObject_1" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2" />
    <bpmn:task id="Task_4" name="Registrar merchandising por unidad, sin pallet/factor (opcional)">
      <bpmn:incoming>Flow_5_unidad</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_1" name="¿Unidad comercial del código?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4_caja</bpmn:outgoing>
      <bpmn:outgoing>Flow_5_unidad</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_2" name="Registrar pedido de ingreso: datos de transporte (placa, chofer, brevete, usuario, fecha/hora)">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:property id="Property_1c0pskq" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_1">
        <bpmn:sourceRef>DataObjectReference_1</bpmn:sourceRef>
        <bpmn:targetRef>Property_1c0pskq</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_1ki3svm">
      <bpmn:incoming>Flow_02xvfxq</bpmn:incoming>
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_1bbrqo1</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_5_unidad" name="unidad" sourceRef="Gateway_1" targetRef="Task_4" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_4" targetRef="Gateway_1ki3svm" />
    <bpmn:sequenceFlow id="Flow_4_caja" name="caja" sourceRef="Gateway_1" targetRef="Task_3" />
    <bpmn:sequenceFlow id="Flow_02xvfxq" sourceRef="Task_3" targetRef="Gateway_1ki3svm" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="Gateway_1" />
    <bpmn:sequenceFlow id="Flow_1bbrqo1" sourceRef="Gateway_1ki3svm" targetRef="Task_5" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_5" targetRef="EndEvent_1" />
    <bpmn:task id="Task_5" name="Firmar pedido de ingreso (analista, chofer, almacén)">
      <bpmn:incoming>Flow_1bbrqo1</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_1" name="Fin Procedimiento 1 (continúa en P2: Verificación)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_3" name="Registrar pallet, factor y suma de cajas (cajas = pallets × factor)">
      <bpmn:incoming>Flow_4_caja</bpmn:incoming>
      <bpmn:outgoing>Flow_02xvfxq</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_1_di" bpmnElement="Participant_1" isHorizontal="true">
        <dc:Bounds x="105" y="-60" width="1115" height="460" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Cliente_di" bpmnElement="Lane_Cliente" isHorizontal="true">
        <dc:Bounds x="135" y="-60" width="1085" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Analista_Inventarios_di" bpmnElement="Lane_Analista_Inventarios" isHorizontal="true">
        <dc:Bounds x="135" y="140" width="1085" height="260" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_1_di" bpmnElement="Task_1">
        <dc:Bounds x="295" y="-10" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="187" y="12" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="192" y="55" width="26" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataObjectReference_1_di" bpmnElement="DataObjectReference_1">
        <dc:Bounds x="452" y="-25" width="36" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="468" y="35" width="84" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_4_di" bpmnElement="Task_4">
        <dc:Bounds x="715" y="305" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_1_di" bpmnElement="Gateway_1" isMarkerVisible="true">
        <dc:Bounds x="600" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="547" y="295" width="65" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_2_di" bpmnElement="Task_2">
        <dc:Bounds x="400" y="240" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_1ki3svm_di" bpmnElement="Gateway_1ki3svm" isMarkerVisible="true">
        <dc:Bounds x="855" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_5_di" bpmnElement="Task_5">
        <dc:Bounds x="970" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1132" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1105" y="305" width="90" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_3_di" bpmnElement="Task_3">
        <dc:Bounds x="715" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="223" y="30" />
        <di:waypoint x="295" y="30" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="345" y="70" />
        <di:waypoint x="345" y="280" />
        <di:waypoint x="400" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_unidad_di" bpmnElement="Flow_5_unidad">
        <di:waypoint x="625" y="305" />
        <di:waypoint x="625" y="345" />
        <di:waypoint x="715" y="345" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="629" y="328" width="34" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="815" y="345" />
        <di:waypoint x="880" y="345" />
        <di:waypoint x="880" y="305" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_caja_di" bpmnElement="Flow_4_caja">
        <di:waypoint x="625" y="255" />
        <di:waypoint x="625" y="210" />
        <di:waypoint x="715" y="210" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="630" y="215" width="21" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_02xvfxq_di" bpmnElement="Flow_02xvfxq">
        <di:waypoint x="815" y="210" />
        <di:waypoint x="880" y="210" />
        <di:waypoint x="880" y="255" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="500" y="280" />
        <di:waypoint x="600" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1bbrqo1_di" bpmnElement="Flow_1bbrqo1">
        <di:waypoint x="905" y="280" />
        <di:waypoint x="970" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1070" y="280" />
        <di:waypoint x="1132" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="DataOutputAssociation_1_di" bpmnElement="DataOutputAssociation_1">
        <di:waypoint x="395" y="0" />
        <di:waypoint x="452" y="0" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="DataInputAssociation_1_di" bpmnElement="DataInputAssociation_1">
        <di:waypoint x="461" y="25" />
