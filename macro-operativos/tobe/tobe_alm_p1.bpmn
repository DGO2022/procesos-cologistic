<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions 
  
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  
  
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  
  
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  
  
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="Camunda Modeler" exporterVersion="5.22.0" 
  
  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="TO-BE: Transferencia de ubicación" processRef="Proc_tobe_alm_p1" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_tobe_alm_p1" isExecutable="true">
    <bpmn:documentation>TO-BE — Almacenamiento P1. El sistema sugiere lote y ubicación destino; la actualización de inventario es automática.</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="LA" name="Analista de inventarios">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ST2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_1" name="Inicio">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="T1" name="Ingresar código a transferir">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="ST1" name="Sugerir lote y ubicación destino">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="T2" name="Confirmar o ajustar selección">
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T3" name="Ejecutar transferencia">
      <bpmn:incoming>F4</bpmn:incoming>
      <bpmn:outgoing>F5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="ST2" name="Actualizar inventario automáticamente">
      <bpmn:incoming>F5</bpmn:incoming>
      <bpmn:outgoing>F6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_1" name="Fin">
      <bpmn:incoming>F6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="Start_1" targetRef="T1"/>
    <bpmn:sequenceFlow id="F2" sourceRef="T1" targetRef="ST1"/>
    <bpmn:sequenceFlow id="F3" sourceRef="ST1" targetRef="T2"/>
    <bpmn:sequenceFlow id="F4" sourceRef="T2" targetRef="T3"/>
    <bpmn:sequenceFlow id="F5" sourceRef="T3" targetRef="ST2"/>
    <bpmn:sequenceFlow id="F6" sourceRef="ST2" targetRef="End_1"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="P_di" bpmnElement="Participant_1" isHorizontal="true">
        <dc:Bounds x="130" y="80" width="1200" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LA_di" bpmnElement="LA" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1170" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_di" bpmnElement="Start_1">
        <dc:Bounds x="202" y="172" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="197" y="215" width="48" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T1_di" bpmnElement="T1">
        <dc:Bounds x="290" y="150" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST1_di" bpmnElement="ST1">
        <dc:Bounds x="450" y="150" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T2_di" bpmnElement="T2">
        <dc:Bounds x="640" y="150" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="T3_di" bpmnElement="T3">
        <dc:Bounds x="810" y="150" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ST2_di" bpmnElement="ST2">
        <dc:Bounds x="980" y="150" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_di" bpmnElement="End_1">
        <dc:Bounds x="1162" y="172" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1172" y="215" width="16" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="F1_di" bpmnElement="F1">
        <di:waypoint x="238" y="190"/>
        <di:waypoint x="290" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F2_di" bpmnElement="F2">
        <di:waypoint x="390" y="190"/>
        <di:waypoint x="450" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F3_di" bpmnElement="F3">
        <di:waypoint x="570" y="190"/>
        <di:waypoint x="640" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F4_di" bpmnElement="F4">
        <di:waypoint x="740" y="190"/>
        <di:waypoint x="810" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F5_di" bpmnElement="F5">
        <di:waypoint x="910" y="190"/>
        <di:waypoint x="980" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F6_di" bpmnElement="F6">
        <di:waypoint x="1100" y="190"/>
        <di:waypoint x="1162" y="190"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
