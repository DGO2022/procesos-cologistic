<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_1"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  exporter="Camunda Modeler"
                  exporterVersion="5.22.0"
                  modeler:executionPlatform="Camunda Cloud"
                  modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Procedimiento Transferencia de zona u ubicación" processRef="Process_Almacenamiento_Transferencia" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Almacenamiento_Transferencia" isExecutable="true">
    <bpmn:documentation>Co Logistic SAC — Proceso: Almacenamiento
Procedimiento 1: Transferencia de ubicación
Fuente: 5-Flujos-otros.txt (fragmento "en las transferencias... código A de la ubicación C a la D...")
Elementos BPMN representados:
  - Evento de inicio (Start Event)
  - Tareas (Task)
  - Compuerta exclusiva (Exclusive Gateway / XOR) todo vs. una fecha
  - Artefacto de datos / Data Object (reporte de movimientos)
  - Evento de fin (End Event)
  - Lane: Analista de inventarios (procedimiento de sistema, sin intervención física narrada en la fuente)</bpmn:documentation>

    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Analista_Inventarios" name="Analista de inventarios">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_1" name="Inicio: necesidad de mover un código">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_1" name="Ingresar código a transferir">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_2" name="Consultar fechas de vencimiento disponibles del código">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_1" name="¿Transferir todo o una fecha?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4_todo</bpmn:outgoing>
      <bpmn:outgoing>Flow_5_fecha</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_3" name="Seleccionar todas las fechas del código">
      <bpmn:incoming>Flow_4_todo</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_4" name="Seleccionar una fecha de vencimiento específica">
      <bpmn:incoming>Flow_5_fecha</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_5" name="Indicar ubicación origen y destino">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_6" name="Ejecutar transferencia">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1">
        <bpmn:targetRef>DataObjectReference_1</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>

    <bpmn:dataObjectReference id="DataObjectReference_1" name="Reporte de movimientos (artefacto de datos)" dataObjectRef="DataObject_1" />
    <bpmn:dataObject id="DataObject_1" />

    <bpmn:endEvent id="EndEvent_1" name="Fin">
      <bpmn:incoming>Flow_9</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="Gateway_1" />
    <bpmn:sequenceFlow id="Flow_4_todo" name="todo" sourceRef="Gateway_1" targetRef="Task_3" />
    <bpmn:sequenceFlow id="Flow_5_fecha" name="una fecha" sourceRef="Gateway_1" targetRef="Task_4" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_3" targetRef="Task_5" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_4" targetRef="Task_5" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_5" targetRef="Task_6" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_6" targetRef="EndEvent_1" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_1_di" bpmnElement="Participant_1" isHorizontal="true">
        <dc:Bounds x="130" y="80" width="1330" height="250" />
      </bpmndi:BPMNShape>
      <!-- Layout for Lane -->
      <bpmndi:BPMNShape id="Lane_Analista_Inventarios_di" bpmnElement="Lane_Analista_Inventarios" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1300" height="250" />
      </bpmndi:BPMNShape>
      
      <!-- Nodes layout -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="212" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="189" y="225" width="83" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_1_di" bpmnElement="Task_1">
        <dc:Bounds x="300" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_2_di" bpmnElement="Task_2">
        <dc:Bounds x="460" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_1_di" bpmnElement="Gateway_1" isMarkerVisible="true">
        <dc:Bounds x="625" y="175" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="608" y="232" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_3_di" bpmnElement="Task_3">
        <dc:Bounds x="730" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_4_di" bpmnElement="Task_4">
        <dc:Bounds x="730" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_5_di" bpmnElement="Task_5">
        <dc:Bounds x="890" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_6_di" bpmnElement="Task_6">
        <dc:Bounds x="1050" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="DataObjectReference_1_di" bpmnElement="DataObjectReference_1">
        <dc:Bounds x="1082" y="275" width="36" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1066" y="332" width="69" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1212" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1222" y="225" width="16" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Edges Layout -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="248" y="200" />
        <di:waypoint x="300" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="400" y="200" />
        <di:waypoint x="460" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="560" y="200" />
        <di:waypoint x="625" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_todo_di" bpmnElement="Flow_4_todo">
        <di:waypoint x="650" y="175" />
        <di:waypoint x="650" y="140" />
        <di:waypoint x="730" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_fecha_di" bpmnElement="Flow_5_fecha">
        <di:waypoint x="650" y="225" />
        <di:waypoint x="650" y="260" />
        <di:waypoint x="730" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="830" y="140" />
        <di:waypoint x="860" y="140" />
        <di:waypoint x="860" y="200" />
        <di:waypoint x="890" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="830" y="260" />
        <di:waypoint x="860" y="260" />
        <di:waypoint x="860" y="200" />
        <di:waypoint x="890" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="990" y="200" />
        <di:waypoint x="1050" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1150" y="200" />
        <di:waypoint x="1212" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="DataOutputAssociation_1_di" bpmnElement="DataOutputAssociation_1">
        <di:waypoint x="1100" y="240" />
        <di:waypoint x="1100" y="275" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
