C4Component
    title Componentes del MS Maestros — ERP CO LOGISTIC S.A.C.

    Container(gateway, "API Gateway", "Spring Cloud Gateway", "Enruta al MS Maestros")
    ContainerDb(db, "PostgreSQL — schema maestros", "Puerto 5432", "Tablas: producto, cliente, almacen, pallet")

    Container_Boundary(ms_mae, "MS Maestros — Spring Boot 3 (Puerto 8083)") {

        Container_Boundary(g_producto, "Productos") {
            Component(producto_ctrl, "ProductoController", "@RestController", "CRUD de productos: SKU, categoría y unidad")
            Component(producto_svc, "ProductoService", "@Service", "Valida SKU único y gestiona atributos")
            Component(producto_repo, "ProductoRepository", "@Repository", "Persiste productos")
        }

        Container_Boundary(g_soporte, "Soporte Transversal") {
            Component(maestro_mapper, "MaestroMapper", "MapStruct", "Entidades maestras ↔ DTOs")
            Component(maestro_validator, "MaestroValidator", "@Component", "Valida unicidad de SKU, RUC y capacidad")
            Component(ex_handler, "GlobalExceptionHandler", "@ControllerAdvice", "Maneja duplicados y referencias no encontradas")
            Component(jwt_filter, "JwtAuthFilter", "@OncePerRequestFilter", "Valida token JWT")
        }
        
        Container_Boundary(g_cliente, "Clientes") {
            Component(cliente_ctrl, "ClienteController", "@RestController", "CRUD de clientes arrendadores")
            Component(cliente_svc, "ClienteService", "@Service", "Valida RUC único y gestiona contratos")
            Component(cliente_repo, "ClienteRepository", "@Repository", "Persiste clientes arrendadores")
        }

        Container_Boundary(g_almacen, "Almacenes y Pallets") {
            Component(almacen_ctrl, "AlmacenController", "@RestController", "CRUD de almacenes, zonas y capacidad")
            Component(almacen_svc, "AlmacenService", "@Service", "Gestiona estructura física y capacidad")
            Component(almacen_repo, "AlmacenRepository", "@Repository", "Persiste almacenes y zonas")
            Component(pallet_ctrl, "PalletController", "@RestController", "CRUD de tipos de pallet y factores")
            Component(pallet_svc, "PalletService", "@Service", "Gestiona tipos de pallet por cliente")
            Component(pallet_repo, "PalletRepository", "@Repository", "Persiste tipos de pallet")
        }

    }

    Rel(gateway, producto_ctrl, "Enruta peticiones /maestros/**", "HTTP")

    Rel(producto_ctrl, producto_svc, "Delega CRUD productos", "")
    Rel(producto_svc, maestro_validator, "Valida SKU", "")
    Rel(producto_svc, producto_repo, "CRUD en BD", "JPA")
    Rel(producto_svc, maestro_mapper, "Convierte a DTO", "")

    Rel(cliente_ctrl, cliente_svc, "Delega CRUD clientes", "")
    Rel(cliente_svc, maestro_validator, "Valida RUC", "")
    Rel(cliente_svc, cliente_repo, "CRUD en BD", "JPA")

    Rel(almacen_ctrl, almacen_svc, "Delega CRUD almacenes", "")
    Rel(almacen_svc, almacen_repo, "CRUD en BD", "JPA")
    Rel(pallet_ctrl, pallet_svc, "Delega CRUD pallets", "")
    Rel(pallet_svc, pallet_repo, "CRUD en BD", "JPA")

    UpdateElementStyle(producto_ctrl, $fontColor="black", $bgColor="#e8f5e9", $borderColor="#2e7d32")
    UpdateElementStyle(cliente_ctrl, $fontColor="black", $bgColor="#e8f5e9", $borderColor="#2e7d32")
    UpdateElementStyle(almacen_ctrl, $fontColor="black", $bgColor="#e8f5e9", $borderColor="#2e7d32")
    UpdateElementStyle(pallet_ctrl, $fontColor="black", $bgColor="#e8f5e9", $borderColor="#2e7d32")
    UpdateElementStyle(producto_svc, $fontColor="black", $bgColor="#e1f5fe", $borderColor="#01579b")
    UpdateElementStyle(cliente_svc, $fontColor="black", $bgColor="#e1f5fe", $borderColor="#01579b")
    UpdateElementStyle(almacen_svc, $fontColor="black", $bgColor="#e1f5fe", $borderColor="#01579b")
    UpdateElementStyle(pallet_svc, $fontColor="black", $bgColor="#e1f5fe", $borderColor="#01579b")
    UpdateElementStyle(producto_repo, $fontColor="black", $bgColor="#fff9c4", $borderColor="#fbc02d")
    UpdateElementStyle(cliente_repo, $fontColor="black", $bgColor="#fff9c4", $borderColor="#fbc02d")
    UpdateElementStyle(almacen_repo, $fontColor="black", $bgColor="#fff9c4", $borderColor="#fbc02d")
    UpdateElementStyle(pallet_repo, $fontColor="black", $bgColor="#fff9c4", $borderColor="#fbc02d")
    UpdateElementStyle(maestro_mapper, $fontColor="black", $bgColor="#f3e5f5", $borderColor="#6a1b9a")
    UpdateElementStyle(maestro_validator, $fontColor="black", $bgColor="#f3e5f5", $borderColor="#6a1b9a")
    UpdateElementStyle(ex_handler, $fontColor="black", $bgColor="#ffebee", $borderColor="#c62828")
    UpdateElementStyle(jwt_filter, $fontColor="black", $bgColor="#d1c4e9", $borderColor="#4527a0")
    UpdateLayoutConfig($c4ShapeInRow="4", $c4BoundaryInRow="5")
