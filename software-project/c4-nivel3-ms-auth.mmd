C4Component
    title Componentes del MS Autenticación — ERP CO LOGISTIC S.A.C.

    Container(gateway, "API Gateway", "Spring Cloud Gateway", "Enruta al MS Autenticación")
    ContainerDb(db, "PostgreSQL — schema auth", "Puerto 5432", "Tablas: usuario, token_blacklist")

    Container_Boundary(ms_auth, "MS Autenticación — Spring Boot 3 (Puerto 8081)") {

        Container_Boundary(g_tokens, "Emisión de Tokens") {
            Component(login_ctrl, "LoginController", "@RestController", "POST /auth/login")
            Component(auth_svc, "AuthService", "@Service", "Orquesta login, refresco y cierre de sesión")
            Component(token_svc, "TokenService", "@Service", "Genera y valida tokens JWT")
            Component(pass_encoder, "PasswordEncoder", "BCrypt", "Verifica contraseñas")
            Component(auth_repo, "AuthRepository", "@Repository", "Consulta credenciales por username")
        }

        Container_Boundary(g_invalidacion, "Gestión de Sesión") {
            Component(refresh_ctrl, "RefreshController", "@RestController", "POST /auth/refresh")
            Component(logout_ctrl, "LogoutController", "@RestController", "POST /auth/logout")
            Component(blacklist_svc, "BlacklistService", "@Service", "Registra tokens revocados")
            Component(blacklist_repo, "BlacklistRepository", "@Repository", "Persiste tokens revocados")
        }

        Container_Boundary(g_infra, "Infraestructura") {
            Component(ex_handler, "GlobalExceptionHandler", "@ControllerAdvice", "Maneja credenciales inválidas y tokens expirados")
            Component(jwt_filter, "JwtAuthFilter", "@OncePerRequestFilter", "Valida token JWT en cada petición")
        }
    }

    Rel(gateway, login_ctrl, "Enruta peticiones /auth/**", "HTTP")

    Rel(login_ctrl, auth_svc, "Valida credenciales", "")
    Rel(refresh_ctrl, auth_svc, "Solicita refresco", "")
    Rel(logout_ctrl, auth_svc, "Solicita revocación", "")
    Rel(auth_svc, token_svc, "Genera y valida JWT", "")
    Rel(auth_svc, pass_encoder, "Verifica contraseña", "")
    Rel(auth_svc, auth_repo, "Consulta credenciales", "JPA")
    Rel(auth_svc, blacklist_svc, "Registra token revocado", "")
    Rel(blacklist_svc, blacklist_repo, "Persiste revocación", "JPA")

    UpdateElementStyle(login_ctrl, $fontColor="black", $bgColor="#e8f5e9", $borderColor="#2e7d32")
    UpdateElementStyle(refresh_ctrl, $fontColor="black", $bgColor="#e8f5e9", $borderColor="#2e7d32")
    UpdateElementStyle(logout_ctrl, $fontColor="black", $bgColor="#e8f5e9", $borderColor="#2e7d32")
    UpdateElementStyle(auth_svc, $fontColor="black", $bgColor="#e1f5fe", $borderColor="#01579b")
    UpdateElementStyle(token_svc, $fontColor="black", $bgColor="#e1f5fe", $borderColor="#01579b")
    UpdateElementStyle(blacklist_svc, $fontColor="black", $bgColor="#e1f5fe", $borderColor="#01579b")
    UpdateElementStyle(pass_encoder, $fontColor="black", $bgColor="#e1f5fe", $borderColor="#01579b")
    UpdateElementStyle(auth_repo, $fontColor="black", $bgColor="#fff9c4", $borderColor="#fbc02d")
    UpdateElementStyle(blacklist_repo, $fontColor="black", $bgColor="#fff9c4", $borderColor="#fbc02d")
    UpdateElementStyle(ex_handler, $fontColor="black", $bgColor="#ffebee", $borderColor="#c62828")
    UpdateElementStyle(jwt_filter, $fontColor="black", $bgColor="#d1c4e9", $borderColor="#4527a0")
    UpdateLayoutConfig($c4ShapeInRow="5", $c4BoundaryInRow="5")
