C4Component
    title Componentes del MS Pedidos y Despacho — ERP CO LOGISTIC S.A.C.

    Container(gateway, "API Gateway", "Spring Cloud Gateway", "Enruta al MS Pedidos y Despacho")
    ContainerDb(db, "PostgreSQL — schema pedidos", "Puerto 5432", "Tablas: pedido_salida, picking, despacho")

    Container_Boundary(ms_des, "MS Pedidos y Despacho — Spring Boot 3 (Puerto 8086)") {

        Container_Boundary(g_pedido, "Pedido de Salida") {
            Component(pedido_ctrl, "PedidoSalidaController", "@RestController", "POST /despacho/pedido — registra pedido de salida")
            Component(pedido_svc, "PedidoSalidaService", "@Service", "Selección FEFO y coordina reserva con MS Inventario")
            Component(pedido_repo, "PedidoSalidaRepository", "@Repository", "Persiste pedidos de salida y líneas por código")
            Component(despacho_validator, "DespachoValidator", "@Component", "Valida stock, lote FEFO y datos del transportista")
            Component(despacho_mapper, "DespachoMapper", "MapStruct", "Entidades de despacho ↔ DTOs y PDF")
        }

        Container_Boundary(g_picking, "Picking") {
            Component(picking_ctrl, "PickingController", "@RestController", "GET /despacho/picking — genera lista por zona")
            Component(picking_svc, "PickingService", "@Service", "Genera lista de picking ordenada por zona y pasillo")
            Component(picking_repo, "PickingRepository", "@Repository", "Persiste y consulta listas de picking")
        }

        Container_Boundary(g_despacho, "Despacho y Guía") {
            Component(despacho_ctrl, "DespachoController", "@RestController", "PUT /despacho/confirmar — cierra el pedido")
            Component(despacho_svc, "DespachoService", "@Service", "Confirma despacho y notifica descuento a MS Inventario")
            Component(despacho_repo, "DespachoRepository", "@Repository", "Persiste despachos confirmados con historial")
            Component(guia_ctrl, "GuiaController", "@RestController", "GET /despacho/guia — genera guía de remisión PDF")
            Component(guia_svc, "GuiaService", "@Service", "Genera guía de remisión con datos del pedido aprobado")
        }

        Container_Boundary(g_infra, "Infraestructura") {
            Component(ex_handler, "GlobalExceptionHandler", "@ControllerAdvice", "Maneja stock insuficiente y pedido no encontrado")
            Component(jwt_filter, "JwtAuthFilter", "@OncePerRequestFilter", "Valida token JWT y rol Analista de Inventarios")
        }
    }

    Rel(gateway, pedido_ctrl, "Enruta peticiones /despacho/**", "HTTP")

    Rel(pedido_ctrl, pedido_svc, "Delega registro de pedido de salida", "")
    Rel(pedido_svc, despacho_validator, "Valida stock y lotes FEFO", "")
    Rel(pedido_svc, pedido_repo, "Persiste pedido de salida", "JPA")
    Rel(pedido_svc, despacho_mapper, "Convierte a DTO", "")

    Rel(picking_ctrl, picking_svc, "Delega generación de picking", "")
    Rel(picking_svc, picking_repo, "Persiste lista de picking", "JPA")

    Rel(despacho_ctrl, despacho_svc, "Delega confirmación", "")
    Rel(despacho_svc, despacho_repo, "Persiste despacho confirmado", "JPA")
    Rel(guia_ctrl, guia_svc, "Delega generación de guía", "")
    Rel(guia_svc, pedido_repo, "Lee datos del pedido aprobado", "JPA")

    UpdateElementStyle(pedido_ctrl, $fontColor="black", $bgColor="#e8f5e9", $borderColor="#2e7d32")
    UpdateElementStyle(picking_ctrl, $fontColor="black", $bgColor="#e8f5e9", $borderColor="#2e7d32")
    UpdateElementStyle(despacho_ctrl, $fontColor="black", $bgColor="#e8f5e9", $borderColor="#2e7d32")
    UpdateElementStyle(guia_ctrl, $fontColor="black", $bgColor="#e8f5e9", $borderColor="#2e7d32")
    UpdateElementStyle(pedido_svc, $fontColor="black", $bgColor="#e1f5fe", $borderColor="#01579b")
    UpdateElementStyle(picking_svc, $fontColor="black", $bgColor="#e1f5fe", $borderColor="#01579b")
    UpdateElementStyle(despacho_svc, $fontColor="black", $bgColor="#e1f5fe", $borderColor="#01579b")
    UpdateElementStyle(guia_svc, $fontColor="black", $bgColor="#e1f5fe", $borderColor="#01579b")
    UpdateElementStyle(pedido_repo, $fontColor="black", $bgColor="#fff9c4", $borderColor="#fbc02d")
    UpdateElementStyle(picking_repo, $fontColor="black", $bgColor="#fff9c4", $borderColor="#fbc02d")
    UpdateElementStyle(despacho_repo, $fontColor="black", $bgColor="#fff9c4", $borderColor="#fbc02d")
    UpdateElementStyle(despacho_mapper, $fontColor="black", $bgColor="#f3e5f5", $borderColor="#6a1b9a")
    UpdateElementStyle(despacho_validator, $fontColor="black", $bgColor="#f3e5f5", $borderColor="#6a1b9a")
    UpdateElementStyle(ex_handler, $fontColor="black", $bgColor="#ffebee", $borderColor="#c62828")
    UpdateElementStyle(jwt_filter, $fontColor="black", $bgColor="#d1c4e9", $borderColor="#4527a0")
    UpdateLayoutConfig($c4ShapeInRow="5", $c4BoundaryInRow="5")
