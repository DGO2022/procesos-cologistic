<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_TalentoHumano" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="4.0.0">
  <bpmn:collaboration id="Collaboration_Talento">
    <bpmn:participant id="Participant_Reclutamiento" name="Reclutamiento de Personal" processRef="Process_Reclutamiento" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Reclutamiento" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Talento">
      <bpmn:lane id="Lane_Candidatos" name="Candidatos">
        <bpmn:flowNodeRef>Task_Postula</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_RRHH" name="RR.HH.">
        <bpmn:flowNodeRef>Task_Conv</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Jefe" name="Jefe de Operaciones">
        <bpmn:flowNodeRef>StartEvent_Vacante</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Req</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Eval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Contratado</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Gerencia" name="Gerencia General">
        <bpmn:flowNodeRef>Task_Contrata</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Vacante" name="Inicio: Vacante">
      <bpmn:outgoing>Flow_StartReq</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Req" name="Definición de perfiles de puesto">
      <bpmn:incoming>Flow_StartReq</bpmn:incoming>
      <bpmn:outgoing>Flow_ReqConv</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Eval" name="Evaluación y selección de estibadores">
      <bpmn:incoming>Flow_ConvEval</bpmn:incoming>
      <bpmn:outgoing>Flow_EvalContrata</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_Contratado" name="Personal Contratado">
      <bpmn:incoming>Flow_ContrataFin</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Conv" name="Convocatoria y Reclutamiento">
      <bpmn:incoming>Flow_ReqConv</bpmn:incoming>
      <bpmn:incoming>Flow_PostulaConv</bpmn:incoming>
      <bpmn:outgoing>Flow_ConvEval</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Postula" name="Envío de CVs / Postulaciones">
      <bpmn:outgoing>Flow_PostulaConv</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Contrata" name="Contratación e Inducción (Alta planilla, SCTR/EPP)">
      <bpmn:incoming>Flow_EvalContrata</bpmn:incoming>
      <bpmn:outgoing>Flow_ContrataFin</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_StartReq" sourceRef="StartEvent_Vacante" targetRef="Task_Req" />
    <bpmn:sequenceFlow id="Flow_ReqConv" name="Perfil aprobado" sourceRef="Task_Req" targetRef="Task_Conv" />
    <bpmn:sequenceFlow id="Flow_PostulaConv" name="Envío CVs" sourceRef="Task_Postula" targetRef="Task_Conv" />
    <bpmn:sequenceFlow id="Flow_ConvEval" name="Candidatos aptos" sourceRef="Task_Conv" targetRef="Task_Eval" />
    <bpmn:sequenceFlow id="Flow_EvalContrata" name="Candidato seleccionado" sourceRef="Task_Eval" targetRef="Task_Contrata" />
    <bpmn:sequenceFlow id="Flow_ContrataFin" sourceRef="Task_Contrata" targetRef="EndEvent_Contratado" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Talento">
    <bpmndi:BPMNPlane id="BPMNPlane_Talento" bpmnElement="Collaboration_Talento">
      <bpmndi:BPMNShape id="Participant_Reclutamiento_di" bpmnElement="Participant_Reclutamiento" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="850" height="600" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Gerencia_di" bpmnElement="Lane_Gerencia" isHorizontal="true">
        <dc:Bounds x="190" y="530" width="820" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Jefe_di" bpmnElement="Lane_Jefe" isHorizontal="true">
        <dc:Bounds x="190" y="380" width="820" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_RRHH_di" bpmnElement="Lane_RRHH" isHorizontal="true">
        <dc:Bounds x="190" y="230" width="820" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Candidatos_di" bpmnElement="Lane_Candidatos" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="820" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Vacante_di" bpmnElement="StartEvent_Vacante">
        <dc:Bounds x="250" y="437" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="241" y="480" width="54" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Req_di" bpmnElement="Task_Req">
        <dc:Bounds x="350" y="415" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Eval_di" bpmnElement="Task_Eval">
        <dc:Bounds x="650" y="415" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Contratado_di" bpmnElement="EndEvent_Contratado">
        <dc:Bounds x="900" y="437" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="893" y="480" width="51" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Conv_di" bpmnElement="Task_Conv">
        <dc:Bounds x="500" y="265" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Postula_di" bpmnElement="Task_Postula">
        <dc:Bounds x="500" y="115" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Contrata_di" bpmnElement="Task_Contrata">
        <dc:Bounds x="800" y="565" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_StartReq_di" bpmnElement="Flow_StartReq">
        <di:waypoint x="286" y="455" />
        <di:waypoint x="350" y="455" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ReqConv_di" bpmnElement="Flow_ReqConv">
        <di:waypoint x="400" y="415" />
        <di:waypoint x="400" y="305" />
        <di:waypoint x="500" y="305" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="409" y="343" width="75" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PostulaConv_di" bpmnElement="Flow_PostulaConv">
        <di:waypoint x="550" y="195" />
        <di:waypoint x="550" y="265" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="559" y="223" width="53" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ConvEval_di" bpmnElement="Flow_ConvEval">
        <di:waypoint x="600" y="305" />
        <di:waypoint x="700" y="305" />
        <di:waypoint x="700" y="415" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="607" y="313" width="86" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EvalContrata_di" bpmnElement="Flow_EvalContrata">
        <di:waypoint x="700" y="495" />
        <di:waypoint x="700" y="605" />
        <di:waypoint x="800" y="605" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="708" y="546" width="63" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ContrataFin_di" bpmnElement="Flow_ContrataFin">
        <di:waypoint x="900" y="605" />
        <di:waypoint x="918" y="605" />
        <di:waypoint x="918" y="473" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
