flowchart TD
    %% Definición de Carriles (Swimlanes)
    
    subgraph Candidatos ["Candidatos"]
        Postula[Envío de CVs / Postulaciones]
    end

    subgraph RRHH ["RR.HH."]
        Conv[2. Convocatoria y Reclutamiento: Publicación y filtro curricular inicial]
    end

    subgraph JefeOperaciones ["Jefe de Operaciones / Área de Operaciones"]
        Start((Inicio:<br>Vacante))
        Req[1. Definición de perfiles de puesto: Análisis de tareas y requisitos]
        Eval[3. Evaluación y selección de estibadores: Entrevistas y pruebas técnicas en almacén]
        Fin((Fin:<br>Personal Contratado))
    end

    subgraph Gerencia ["Gerencia General"]
        Contrata[4. Contratación e Inducción: Alta en planilla y asignación de SCTR/EPP]
    end

    %% Secuencia del proceso
    Start --> Req
    Req -->|Perfil de puesto aprobado| Conv
    Postula -.->|CVs| Conv
    Conv -->|Lista de candidatos aptos| Eval
    Eval -->|Candidato seleccionado| Contrata
    Contrata -->|Personal contratado y asegurado| Fin

    %% Estilos básicos
    style Start fill:#28a745,stroke:#fff,stroke-width:2px,color:#fff
    style Fin fill:#007bff,stroke:#fff,stroke-width:2px,color:#fff
    style Req fill:#f8f9fa,stroke:#333,stroke-width:1px
    style Conv fill:#f8f9fa,stroke:#333,stroke-width:1px
    style Eval fill:#f8f9fa,stroke:#333,stroke-width:1px
    style Contrata fill:#f8f9fa,stroke:#333,stroke-width:1px
