flowchart TD
    %% Definición de Carriles (Swimlanes)
    
    subgraph Visitante ["Visitante / Conductor"]
        Start((Inicio))
        Doc[Entregar Documentación de Identidad y Seguro SCTR]
        Start --> Doc
    end

    subgraph Vigilante ["Vigilante (Garitero)"]
        Validar[Validación y Seguridad: Recepción y verificación de vigencia de seguros]
        Decision{¿Documentación<br>Válida?}
        FinDenegado((Ingreso<br>Denegado))
        Induccion[Inducción rápida de seguridad: Entrega de EPP e instrucciones de zonas seguras]
    end

    subgraph JefeOperaciones ["Jefe de Operaciones"]
        Registro[Registro de conductores y vehículos: Anotación manual de placa, brevete y hora]
        Pase[Emitir Pase de ingreso autorizado <br>Hoja de control]
        FinAutorizado((Ingreso<br>Autorizado))
    end

    subgraph Analista ["Analista de Inventarios / Almacén"]
        Receptor[Recepción de visitante en planta]
    end

    %% Secuencia del proceso
    Doc --> Validar
    Validar --> Decision
    Decision -- No --> FinDenegado
    Decision -- Sí --> Induccion
    Induccion --> Registro
    Registro --> Pase
    Pase --> FinAutorizado
    Pase -.->|Pase de Ingreso| Receptor

    %% Estilos básicos
    style Start fill:#28a745,stroke:#fff,stroke-width:2px,color:#fff
    style FinDenegado fill:#dc3545,stroke:#fff,stroke-width:2px,color:#fff
    style FinAutorizado fill:#007bff,stroke:#fff,stroke-width:2px,color:#fff
    style Decision fill:#ffc107,stroke:#333,stroke-width:2px,color:#000
