<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.22.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Procedimiento Liquidación" processRef="Process_Facturacion_Liquidacion" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Facturacion_Liquidacion" isExecutable="true">
    <bpmn:documentation>Co Logistic SAC — Proceso de apoyo: Facturación
Procedimiento único: Liquidación mensual in-out y servicios
Fuente: 3-Facturacion.txt, Personal-Encargado-Sunat.txt, 9-Auditorias-trazabilidad.txt
Elementos BPMN representados:
  - Evento de inicio (Start Event, temporal/cíclico: cierre de mes)
  - Tareas (Task)
  - Compuerta exclusiva (Exclusive Gateway / XOR) tipo de tarifa
  - Artefactos de datos / Data Objects (reporte de movimientos, Excel, factura)
  - Evento de fin (End Event)
  - Pools/Lanes: Analista de inventarios, Contador
Nota: proceso de apoyo, no misional. Se ejecuta una vez al mes, desacoplado del despacho/recepción ("nunca interviene en la salida de despacho"). Brecha confirmada: 100% manual en Excel, sin soporte en el sistema.</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Analista_Inventarios" name="Analista de inventarios">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_4</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Contador" name="Contador">
        <bpmn:flowNodeRef>Task_6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_7</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_8</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="Inicio: cierre de mes">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_1" name="Filtrar reporte de movimientos por tipo de producto y mes">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:property id="Property_1ns3jag" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_1">
        <bpmn:sourceRef>DataObjectReference_1</bpmn:sourceRef>
        <bpmn:targetRef>Property_1ns3jag</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_2" name="Incluir reportes de Acondicionamiento (repaletizado, reencajado)">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_3" name="Exportar reporte a Excel">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_4" name="Enviar reportes al contador">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="Task_3" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_3" targetRef="Task_4" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_4" targetRef="Gateway_1" />
    <bpmn:sequenceFlow id="Flow_6_paleta" name="paleta" sourceRef="Gateway_1" targetRef="Task_5" />
    <bpmn:sequenceFlow id="Flow_7_m2" name="m²" sourceRef="Gateway_1" targetRef="Task_6" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_5" targetRef="Task_7" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_6" targetRef="Task_7" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_7" targetRef="Task_8" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_8" targetRef="EndEvent_1" />
    <bpmn:task id="Task_6" name="Aplicar tarifa por metro cuadrado">
      <bpmn:incoming>Flow_7_m2</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_5" name="Aplicar tarifa por paleta">
      <bpmn:incoming>Flow_6_paleta</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_1" name="¿Tarifa por paleta o m²?">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6_paleta</bpmn:outgoing>
      <bpmn:outgoing>Flow_7_m2</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_7" name="Prorratear por fecha de corte (días/30)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1">
        <bpmn:targetRef>DataObjectReference_2</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_8" name="Emitir factura al cliente">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_2">
        <bpmn:targetRef>DataObjectReference_3</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_1" name="Fin">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:dataObjectReference id="DataObjectReference_3" name="Factura al cliente" dataObjectRef="DataObject_3" />
    <bpmn:dataObject id="DataObject_3" />
    <bpmn:dataObjectReference id="DataObjectReference_2" name="Excel con tarifa aplicada (manual, sin soporte en sistema)" dataObjectRef="DataObject_2" />
    <bpmn:dataObject id="DataObject_2" />
    <bpmn:dataObjectReference id="DataObjectReference_1" name="Reporte de movimientos (artefacto de datos)" dataObjectRef="DataObject_1" />
    <bpmn:dataObject id="DataObject_1" />
  </bpmn:process>
