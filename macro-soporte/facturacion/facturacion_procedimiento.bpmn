<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_1"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  exporter="Camunda Modeler"
                  exporterVersion="5.22.0"
                  modeler:executionPlatform="Camunda Cloud"
                  modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Procedimiento Liquidación" processRef="Process_Facturacion_Liquidacion" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Facturacion_Liquidacion" isExecutable="true">
    <bpmn:documentation>Co Logistic SAC — Proceso de apoyo: Facturación
Procedimiento único: Liquidación mensual in-out y servicios
Fuente: 3-Facturacion.txt, Personal-Encargado-Sunat.txt, 9-Auditorias-trazabilidad.txt
Elementos BPMN representados:
  - Evento de inicio (Start Event, temporal/cíclico: cierre de mes)
  - Tareas (Task)
  - Compuerta exclusiva (Exclusive Gateway / XOR) tipo de tarifa
  - Artefactos de datos / Data Objects (reporte de movimientos, Excel, factura)
  - Evento de fin (End Event)
  - Pools/Lanes: Analista de inventarios, Contador
Nota: proceso de apoyo, no misional. Se ejecuta una vez al mes, desacoplado del despacho/recepción ("nunca interviene en la salida de despacho"). Brecha confirmada: 100% manual en Excel, sin soporte en el sistema.</bpmn:documentation>

    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Analista_Inventarios" name="Analista de inventarios">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_4</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Contador" name="Contador">
        <bpmn:flowNodeRef>Gateway_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_7</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_8</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_1" name="Inicio: cierre de mes">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="Task_1" name="Filtrar reporte de movimientos por tipo de producto y mes">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:dataInputAssociation id="DataInputAssociation_1">
        <bpmn:sourceRef>DataObjectReference_1</bpmn:sourceRef>
        <bpmn:targetRef>Task_1</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:task>

    <bpmn:task id="Task_2" name="Incluir reportes de Acondicionamiento (repaletizado, reencajado)">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_3" name="Exportar reporte a Excel">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_4" name="Enviar reportes al contador">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="Gateway_1" name="¿Tarifa por paleta o m²?">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6_paleta</bpmn:outgoing>
      <bpmn:outgoing>Flow_7_m2</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="Task_5" name="Aplicar tarifa por paleta">
      <bpmn:incoming>Flow_6_paleta</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_6" name="Aplicar tarifa por metro cuadrado">
      <bpmn:incoming>Flow_7_m2</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_7" name="Prorratear por fecha de corte (días/30)">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1">
        <bpmn:targetRef>DataObjectReference_2</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>

    <bpmn:task id="Task_8" name="Emitir factura al cliente">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_2">
        <bpmn:targetRef>DataObjectReference_3</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>

    <bpmn:endEvent id="EndEvent_1" name="Fin">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:dataObjectReference id="DataObjectReference_1" name="Reporte de movimientos (artefacto de datos)" dataObjectRef="DataObject_1" />
    <bpmn:dataObject id="DataObject_1" />

    <bpmn:dataObjectReference id="DataObjectReference_2" name="Excel con tarifa aplicada (manual, sin soporte en sistema)" dataObjectRef="DataObject_2" />
    <bpmn:dataObject id="DataObject_2" />

    <bpmn:dataObjectReference id="DataObjectReference_3" name="Factura al cliente" dataObjectRef="DataObject_3" />
    <bpmn:dataObject id="DataObject_3" />

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="Task_3" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_3" targetRef="Task_4" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_4" targetRef="Gateway_1" />
    <bpmn:sequenceFlow id="Flow_6_paleta" name="paleta" sourceRef="Gateway_1" targetRef="Task_5" />
    <bpmn:sequenceFlow id="Flow_7_m2" name="m²" sourceRef="Gateway_1" targetRef="Task_6" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_5" targetRef="Task_7" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_6" targetRef="Task_7" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_7" targetRef="Task_8" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_8" targetRef="EndEvent_1" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_1_di" bpmnElement="Participant_1" isHorizontal="true">
        <dc:Bounds x="130" y="80" width="1350" height="400" />
      </bpmndi:BPMNShape>
      
      <!-- Layout for Lane -->
      <bpmndi:BPMNShape id="Lane_Analista_Inventarios_di" bpmnElement="Lane_Analista_Inventarios" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1320" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Contador_di" bpmnElement="Lane_Contador" isHorizontal="true">
        <dc:Bounds x="160" y="280" width="1320" height="200" />
      </bpmndi:BPMNShape>
      
      <!-- Nodes layout -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="212" y="152" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_1_di" bpmnElement="Task_1">
        <dc:Bounds x="300" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_2_di" bpmnElement="Task_2">
        <dc:Bounds x="460" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_3_di" bpmnElement="Task_3">
        <dc:Bounds x="620" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_4_di" bpmnElement="Task_4">
        <dc:Bounds x="780" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_1_di" bpmnElement="Gateway_1" isMarkerVisible="true">
        <dc:Bounds x="805" y="355" width="50" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_5_di" bpmnElement="Task_5">
        <dc:Bounds x="920" y="290" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_6_di" bpmnElement="Task_6">
        <dc:Bounds x="920" y="400" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_7_di" bpmnElement="Task_7">
        <dc:Bounds x="1080" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_8_di" bpmnElement="Task_8">
        <dc:Bounds x="1240" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1402" y="362" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Artifacts -->
      <bpmndi:BPMNShape id="DataObjectReference_1_di" bpmnElement="DataObjectReference_1">
        <dc:Bounds x="252" y="210" width="36" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="DataObjectReference_2_di" bpmnElement="DataObjectReference_2">
        <dc:Bounds x="1032" y="450" width="36" height="50" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="DataObjectReference_3_di" bpmnElement="DataObjectReference_3">
        <dc:Bounds x="1192" y="450" width="36" height="50" />
      </bpmndi:BPMNShape>

      <!-- Edges Layout -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="248" y="170" />
        <di:waypoint x="300" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="400" y="170" />
        <di:waypoint x="460" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="560" y="170" />
        <di:waypoint x="620" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="720" y="170" />
        <di:waypoint x="780" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="830" y="210" />
        <di:waypoint x="830" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_paleta_di" bpmnElement="Flow_6_paleta">
        <di:waypoint x="830" y="355" />
        <di:waypoint x="830" y="330" />
        <di:waypoint x="920" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_m2_di" bpmnElement="Flow_7_m2">
        <di:waypoint x="830" y="405" />
        <di:waypoint x="830" y="440" />
        <di:waypoint x="920" y="440" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="1020" y="330" />
        <di:waypoint x="1050" y="330" />
        <di:waypoint x="1050" y="380" />
        <di:waypoint x="1080" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="1020" y="440" />
        <di:waypoint x="1050" y="440" />
        <di:waypoint x="1050" y="380" />
        <di:waypoint x="1080" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1180" y="380" />
        <di:waypoint x="1240" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1340" y="380" />
        <di:waypoint x="1402" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="DataInputAssociation_1_di" bpmnElement="DataInputAssociation_1">
        <di:waypoint x="288" y="235" />
        <di:waypoint x="300" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="DataOutputAssociation_1_di" bpmnElement="DataOutputAssociation_1">
        <di:waypoint x="1130" y="420" />
        <di:waypoint x="1130" y="450" />
        <di:waypoint x="1068" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="DataOutputAssociation_2_di" bpmnElement="DataOutputAssociation_2">
        <di:waypoint x="1290" y="420" />
        <di:waypoint x="1290" y="450" />
        <di:waypoint x="1228" y="450" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
