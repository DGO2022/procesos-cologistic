      <bpmn:outgoing>Flow_C_D</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_D" name="Generar Consolidado de Rentas del Mes">
      <bpmn:incoming>Flow_C_D</bpmn:incoming>
      <bpmn:outgoing>Flow_D_E</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_E" name="Fin">
      <bpmn:incoming>Flow_D_E</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_A_B" sourceRef="StartEvent_1" targetRef="Activity_B" />
    <bpmn:sequenceFlow id="Flow_B_C" sourceRef="Activity_B" targetRef="Activity_C" />
    <bpmn:sequenceFlow id="Flow_C_D" sourceRef="Activity_C" targetRef="Activity_D" />
    <bpmn:sequenceFlow id="Flow_D_E" sourceRef="Activity_D" targetRef="Event_E" />
