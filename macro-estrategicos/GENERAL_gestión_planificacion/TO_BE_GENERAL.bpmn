      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Activity_T4" name="1.2.4 Comunicación y alineamiento organizacional">
      <bpmn:incoming>Flow_T3_T4</bpmn:incoming>
      <bpmn:outgoing>Flow_T4_T5</bpmn:outgoing>
      <bpmn:property id="Property_T4" name="__targetRef_placeholder" />
