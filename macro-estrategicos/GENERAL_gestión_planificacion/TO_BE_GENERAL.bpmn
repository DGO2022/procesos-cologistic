      <bpmn:dataOutputAssociation id="DataOutputAssociation_DO4">
        <bpmn:targetRef>DataObjectReference_DO4</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Activity_T5" name="1.2.5 Seguimiento, control y revisión estratégica">
