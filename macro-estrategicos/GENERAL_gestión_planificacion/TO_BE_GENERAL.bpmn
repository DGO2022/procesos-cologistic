      <bpmn:dataOutputAssociation id="DataOutputAssociation_DO5">
        <bpmn:targetRef>DataObjectReference_DO5</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_1" name="Fin">
      <bpmn:incoming>Flow_T5_End</bpmn:incoming>
    </bpmn:endEvent>
