  <bpmn:collaboration id="Collaboration_TO_BE_GENERAL">
    <bpmn:participant id="Participant_TO_BE_GENERAL" name="Gestión de Planeación Estratégica de TI - TO BE" processRef="Process_TO_BE_GENERAL" />
  </bpmn:collaboration>
  <bpmn:process id="Process_TO_BE_GENERAL" isExecutable="true">
    <bpmn:laneSet id="LaneSet_TO_BE_GENERAL">
      <bpmn:lane id="Lane_ComiteGerencial" name="Comité Gerencial y Gerente General">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_JefaturaTI" name="Jefatura de TI y Área de Gobierno TI">
        <bpmn:flowNodeRef>Activity_T1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_T2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_T3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_T4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_T5</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_JefaturasOperativas" name="Subgerencia y Jefaturas Operativas - Almacén" />
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="Inicio">
      <bpmn:outgoing>Flow_Start_T1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_T1" name="1.2.1 Diagnóstico estratégico organizacional de TI">
      <bpmn:incoming>Flow_Start_T1</bpmn:incoming>
      <bpmn:outgoing>Flow_T1_T2</bpmn:outgoing>
      <bpmn:property id="Property_T1" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_PlanNegocio">
        <bpmn:sourceRef>DataObjectReference_PlanNegocio</bpmn:sourceRef>
        <bpmn:targetRef>Property_T1</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataInputAssociation id="DataInputAssociation_Infra">
        <bpmn:sourceRef>DataObjectReference_Infra</bpmn:sourceRef>
        <bpmn:targetRef>Property_T1</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_DO1">
        <bpmn:targetRef>DataObjectReference_DO1</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Activity_T2" name="1.2.2 Definición de la dirección estratégica de TI">
      <bpmn:incoming>Flow_T1_T2</bpmn:incoming>
      <bpmn:outgoing>Flow_T2_T3</bpmn:outgoing>
      <bpmn:property id="Property_T2" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_DO1">
        <bpmn:sourceRef>DataObjectReference_DO1</bpmn:sourceRef>
        <bpmn:targetRef>Property_T2</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_DO2">
        <bpmn:targetRef>DataObjectReference_DO2</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Activity_T3" name="1.2.3 Formulación de plan estratégico">
      <bpmn:incoming>Flow_T2_T3</bpmn:incoming>
      <bpmn:outgoing>Flow_T3_T4</bpmn:outgoing>
      <bpmn:property id="Property_T3" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_DO2">
