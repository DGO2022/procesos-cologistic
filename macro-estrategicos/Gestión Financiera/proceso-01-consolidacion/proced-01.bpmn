      <bpmndi:BPMNShape id="Activity_D_di" bpmnElement="Activity_D">
        <dc:Bounds x="600" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_E_di" bpmnElement="Activity_E">
        <dc:Bounds x="750" y="130" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_F_di" bpmnElement="Activity_F">
        <dc:Bounds x="900" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_G_di" bpmnElement="Gateway_G" isMarkerVisible="true">
        <dc:Bounds x="1050" y="415" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_H_di" bpmnElement="Activity_H">
        <dc:Bounds x="1150" y="400" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_I_di" bpmnElement="Event_I">
        <dc:Bounds x="1300" y="302" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_A_B_di" bpmnElement="Flow_A_B">
        <di:waypoint x="236" y="170" />
        <di:waypoint x="300" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_B_C_di" bpmnElement="Flow_B_C">
        <di:waypoint x="400" y="170" />
        <di:waypoint x="450" y="170" />
      </bpmndi:BPMNEdge>
