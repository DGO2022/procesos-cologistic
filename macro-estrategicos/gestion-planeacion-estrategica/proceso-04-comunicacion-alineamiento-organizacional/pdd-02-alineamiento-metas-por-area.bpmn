<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1_2_4_2" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1_2_4_2">
    <bpmn:participant id="Participant_1_2_4_2" name="1.2.4.2 Alineamiento de metas por área" processRef="Process_1_2_4_2" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1_2_4_2" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1_2_4_2">
      <bpmn:lane id="Lane_Subgerencia" name="Subgerencia">
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TraducirObjetivos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VincularMetasKPIs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ElaborarFichas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarFichas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_FichasRegistradas</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_JefesArea" name="Jefes de Área">
        <bpmn:flowNodeRef>Task_DefinirMetasArea</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AcordarCompromisos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AjustarMetas</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Colaboradores" name="Colaboradores">
        <bpmn:flowNodeRef>Task_RevisarCompromisos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FirmarFicha</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_GerenciaGeneral" name="Gerencia General">
        <bpmn:flowNodeRef>Task_ValidarFichas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_FichasAlineadas</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio alineamiento de metas">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_TraducirObjetivos" name="Traduce objetivos en metas">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DefinirMetasArea" name="Define metas por área">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AcordarCompromisos" name="Acuerda compromisos del equipo">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RevisarCompromisos" name="Revisa compromisos asignados">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_VincularMetasKPIs" name="Vincula metas con KPIs">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ElaborarFichas" name="Elabora fichas de alineamiento">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ValidarFichas" name="Valida fichas de metas">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_FichasAlineadas" name="¿Fichas alineadas al BSC?">
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_AjustarMetas" name="Ajusta metas o compromisos">
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_FirmarFicha" name="Firma ficha de alineamiento">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RegistrarFichas" name="Registra fichas firmadas">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_TraducirObjetivos" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_TraducirObjetivos" targetRef="Task_DefinirMetasArea" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_DefinirMetasArea" targetRef="Task_AcordarCompromisos" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_AcordarCompromisos" targetRef="Task_RevisarCompromisos" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_RevisarCompromisos" targetRef="Task_VincularMetasKPIs" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_VincularMetasKPIs" targetRef="Task_ElaborarFichas" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Task_ElaborarFichas" targetRef="Task_ValidarFichas" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Task_ValidarFichas" targetRef="Gateway_FichasAlineadas" />
    <bpmn:sequenceFlow id="Flow_09" name="No" sourceRef="Gateway_FichasAlineadas" targetRef="Task_AjustarMetas" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_AjustarMetas" targetRef="Task_ElaborarFichas" />
    <bpmn:sequenceFlow id="Flow_11" name="Sí" sourceRef="Gateway_FichasAlineadas" targetRef="Task_FirmarFicha" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_FirmarFicha" targetRef="Task_RegistrarFichas" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_RegistrarFichas" targetRef="EndEvent_FichasRegistradas" />
    <bpmn:endEvent id="EndEvent_FichasRegistradas" name="Fichas de metas registradas">
      <bpmn:incoming>Flow_13</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1_2_4_2">
    <bpmndi:BPMNPlane id="BPMNPlane_1_2_4_2" bpmnElement="Collaboration_1_2_4_2">
