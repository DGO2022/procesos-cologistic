<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1_2_4_3" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1_2_4_3">
    <bpmn:participant id="Participant_1_2_4_3" name="1.2.4.3 Gestión del cambio organizacional" processRef="Process_1_2_4_3" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1_2_4_3" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1_2_4_3">
      <bpmn:lane id="Lane_Subgerencia" name="Subgerencia">
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IdentificarResistencias</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ResistenciasSignificativas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DisenarAccionesSensibilizacion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MonitorearAdopcion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AdopcionSatisfactoria</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarAdopcion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_CambioAdoptado</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_GerenciaGeneral" name="Gerencia General">
        <bpmn:flowNodeRef>Task_AprobarAcciones</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DefinirAccionesCorrectivas</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_JefesArea" name="Jefes de Área">
        <bpmn:flowNodeRef>Task_ReforzarComunicacion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EjecutarAcciones</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AplicarRefuerzo</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Colaboradores" name="Colaboradores">
        <bpmn:flowNodeRef>Task_ParticiparAccionesCambio</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio gestión del cambio">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_CambioAdoptado" name="Cambio organizacional adoptado">
      <bpmn:incoming>Flow_17</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_IdentificarResistencias" name="Identifica resistencias internas">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ResistenciasSignificativas" name="¿Existen resistencias significativas?">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_DisenarAccionesSensibilizacion" name="Diseña acciones de sensibilización">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReforzarComunicacion" name="Refuerza comunicación del cambio">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AprobarAcciones" name="Aprueba acciones de cambio">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EjecutarAcciones" name="Ejecuta acciones con equipos">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ParticiparAccionesCambio" name="Participa en acciones de cambio">
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_MonitorearAdopcion" name="Monitorea nivel de adopción">
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_AdopcionSatisfactoria" name="¿Adopción satisfactoria?">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_DefinirAccionesCorrectivas" name="Define acciones correctivas">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AplicarRefuerzo" name="Aplica refuerzo al equipo">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RegistrarAdopcion" name="Registra adopción del cambio">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_IdentificarResistencias" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_IdentificarResistencias" targetRef="Gateway_ResistenciasSignificativas" />
    <bpmn:sequenceFlow id="Flow_03" name="Sí" sourceRef="Gateway_ResistenciasSignificativas" targetRef="Task_DisenarAccionesSensibilizacion" />
    <bpmn:sequenceFlow id="Flow_04" name="No" sourceRef="Gateway_ResistenciasSignificativas" targetRef="Task_ReforzarComunicacion" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_DisenarAccionesSensibilizacion" targetRef="Task_AprobarAcciones" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_ReforzarComunicacion" targetRef="Task_AprobarAcciones" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Task_AprobarAcciones" targetRef="Task_EjecutarAcciones" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Task_EjecutarAcciones" targetRef="Task_ParticiparAccionesCambio" />
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Task_ParticiparAccionesCambio" targetRef="Task_MonitorearAdopcion" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_MonitorearAdopcion" targetRef="Gateway_AdopcionSatisfactoria" />
    <bpmn:sequenceFlow id="Flow_11" name="Sí" sourceRef="Gateway_AdopcionSatisfactoria" targetRef="Task_RegistrarAdopcion" />
    <bpmn:sequenceFlow id="Flow_12" name="No" sourceRef="Gateway_AdopcionSatisfactoria" targetRef="Task_DefinirAccionesCorrectivas" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_DefinirAccionesCorrectivas" targetRef="Task_AplicarRefuerzo" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_AplicarRefuerzo" targetRef="Task_MonitorearAdopcion" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Task_RegistrarAdopcion" targetRef="EndEvent_CambioAdoptado" />
  </bpmn:process>
