<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1_2_4_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1_2_4_1">
    <bpmn:participant id="Participant_1_2_4_1" name="1.2.4.1 Difusión del plan estratégico" processRef="Process_1_2_4_1" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1_2_4_1" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1_2_4_1">
      <bpmn:lane id="Lane_Subgerencia" name="Subgerencia">
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PrepararMateriales</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ExplicarObjetivos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarConformidades</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DifundirPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Difundido</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_GerenciaGeneral" name="Gerencia General">
        <bpmn:flowNodeRef>Task_PresentarPlan</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_JefeOperaciones" name="Jefe de Operaciones">
        <bpmn:flowNodeRef>Task_ComunicarPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ResolverDudas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PersonalComprendio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReforzarExplicacion</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_PersonalOperativo" name="Personal Operativo">
        <bpmn:flowNodeRef>Task_RecibirInformacion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FirmarConformidad</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio de difusión del plan">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_Difundido" name="Plan estratégico difundido">
      <bpmn:incoming>Flow_14</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_PrepararMateriales" name="Prepara materiales de comunicación">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_PresentarPlan" name="Presenta plan a jefaturas">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ExplicarObjetivos" name="Explica objetivos estratégicos">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ComunicarPlan" name="Comunica plan al personal operativo">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RecibirInformacion" name="Recibe información del plan">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ResolverDudas" name="Resuelve dudas del equipo">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_PersonalComprendio" name="¿Personal comprendió el plan?">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ReforzarExplicacion" name="Refuerza explicación del plan">
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_FirmarConformidad" name="Firma conformidad de recepción">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RegistrarConformidades" name="Registra conformidades firmadas">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DifundirPlan" name="Difunde plan estratégico">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_PrepararMateriales" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_PrepararMateriales" targetRef="Task_PresentarPlan" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_PresentarPlan" targetRef="Task_ExplicarObjetivos" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_ExplicarObjetivos" targetRef="Task_ComunicarPlan" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_ComunicarPlan" targetRef="Task_RecibirInformacion" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_RecibirInformacion" targetRef="Task_ResolverDudas" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Task_ResolverDudas" targetRef="Gateway_PersonalComprendio" />
    <bpmn:sequenceFlow id="Flow_08" name="No" sourceRef="Gateway_PersonalComprendio" targetRef="Task_ReforzarExplicacion" />
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Task_ReforzarExplicacion" targetRef="Task_ResolverDudas" />
    <bpmn:sequenceFlow id="Flow_10" name="Sí" sourceRef="Gateway_PersonalComprendio" targetRef="Task_FirmarConformidad" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_FirmarConformidad" targetRef="Task_RegistrarConformidades" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_RegistrarConformidades" targetRef="Task_DifundirPlan" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_DifundirPlan" targetRef="EndEvent_Difundido" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1_2_4_1">
