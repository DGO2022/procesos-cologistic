        <di:waypoint x="850" y="230" />
        <di:waypoint x="930" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_06_di" bpmnElement="Flow_06">
        <di:waypoint x="1070" y="230" />
