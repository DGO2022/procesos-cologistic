<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_ConstruccionMatrizFODA" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_ConstruccionMatrizFODA">
    <bpmn:participant id="Participant_ConstruccionMatrizFODA" name="1.2.1.5 Construcción de la matriz FODA" processRef="Process_ConstruccionMatrizFODA" />
  </bpmn:collaboration>
  <bpmn:process id="Process_ConstruccionMatrizFODA" isExecutable="false">
    <bpmn:laneSet id="LaneSet_ConstruccionMatrizFODA">
      <bpmn:lane id="Lane_Subgerencia" name="Subgerencia">
        <bpmn:flowNodeRef>Task_ConsolidarInsumos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ClasificarHallazgos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PriorizarFactores</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnviarFODA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CorregirMatriz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarFODA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0no9vyw</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ComiteGerencial" name="Comité gerencial">
        <bpmn:flowNodeRef>Task_RevisarMatriz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_FODAConsistente</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_GerenciaGeneral" name="Gerencia general">
        <bpmn:flowNodeRef>Task_ValidarMatriz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_FODAAprobado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AprobarFormalmente</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:task id="Task_ConsolidarInsumos" name="Consolidar insumos previos">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ClasificarHallazgos" name="Clasificar hallazgos FODA">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_PriorizarFactores" name="Priorizar factores estratégicos">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EnviarFODA" name="Enviar FODA para revisión">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RevisarMatriz" name="Revisar matriz FODA">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_FODAConsistente" name="¿FODA consistente?">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ValidarMatriz" name="Validar matriz FODA">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_FODAAprobado" name="¿FODA aprobado?">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_AprobarFormalmente" name="Aprobar formalmente FODA">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_ConsolidarInsumos" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_ConsolidarInsumos" targetRef="Task_ClasificarHallazgos" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_ClasificarHallazgos" targetRef="Task_PriorizarFactores" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_PriorizarFactores" targetRef="Task_EnviarFODA" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_EnviarFODA" targetRef="Task_RevisarMatriz" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_RevisarMatriz" targetRef="Gateway_FODAConsistente" />
    <bpmn:sequenceFlow id="Flow_07" name="No" sourceRef="Gateway_FODAConsistente" targetRef="Task_CorregirMatriz" />
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Task_CorregirMatriz" targetRef="Task_ClasificarHallazgos" />
    <bpmn:sequenceFlow id="Flow_10" name="Sí" sourceRef="Gateway_FODAConsistente" targetRef="Task_ValidarMatriz" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_ValidarMatriz" targetRef="Gateway_FODAAprobado" />
    <bpmn:sequenceFlow id="Flow_12" name="Sí" sourceRef="Gateway_FODAAprobado" targetRef="Task_AprobarFormalmente" />
    <bpmn:sequenceFlow id="Flow_14" name="No" sourceRef="Gateway_FODAAprobado" targetRef="Task_CorregirMatriz" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_AprobarFormalmente" targetRef="Task_RegistrarFODA" />
    <bpmn:task id="Task_CorregirMatriz" name="Corregir matriz FODA">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RegistrarFODA" name="Registrar FODA aprobado">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_0059ceh</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_0no9vyw" name="Matriz FODA aprobada">
      <bpmn:incoming>Flow_0059ceh</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0059ceh" sourceRef="Task_RegistrarFODA" targetRef="Event_0no9vyw" />
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio de construcción del FODA">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
  </bpmn:process>
