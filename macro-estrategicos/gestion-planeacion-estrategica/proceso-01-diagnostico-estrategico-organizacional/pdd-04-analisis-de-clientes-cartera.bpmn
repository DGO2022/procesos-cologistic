<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_AnalisisClientesCartera" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_AnalisisClientesCartera">
    <bpmn:participant id="Participant_AnalisisClientesCartera" name="1.2.1.4 Análisis de clientes y cartera" processRef="Process_AnalisisClientesCartera" />
  </bpmn:collaboration>
  <bpmn:process id="Process_AnalisisClientesCartera" isExecutable="false">
    <bpmn:laneSet id="LaneSet_AnalisisClientesCartera">
      <bpmn:lane id="Lane_Subgerencia" name="Subgerencia">
        <bpmn:flowNodeRef>Task_ListarClientes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CalcularDependencia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IdentificarClientesPotenciales</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AmpliarBusquedaClientes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EstimarCrecimiento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CorregirAnalisis</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Aprobado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarAnalisis</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_JefeAlmacen" name="Jefe de almacén">
        <bpmn:flowNodeRef>Task_MapearEstacionalidades</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_GerenciaGeneral" name="Gerencia general">
        <bpmn:flowNodeRef>Gateway_ClientesViables</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarAnalisis</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_AnalisisAprobado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EvaluarViabilidad</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:task id="Task_ListarClientes" name="Listar clientes actuales">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_CalcularDependencia" name="Calcular dependencia por cliente">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_MapearEstacionalidades" name="Mapear estacionalidades operativas">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_IdentificarClientesPotenciales" name="Identificar clientes potenciales">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ClientesViables" name="¿Clientes potenciales viables?">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_AmpliarBusquedaClientes" name="Ampliar búsqueda de clientes">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EstimarCrecimiento" name="Estimar crecimiento de cartera">
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RevisarAnalisis" name="Revisar análisis de cartera">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_AnalisisAprobado" name="¿Análisis aprobado?">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_CorregirAnalisis" name="Corregir análisis de cartera">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_ListarClientes" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_ListarClientes" targetRef="Task_CalcularDependencia" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_CalcularDependencia" targetRef="Task_MapearEstacionalidades" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_MapearEstacionalidades" targetRef="Task_IdentificarClientesPotenciales" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_IdentificarClientesPotenciales" targetRef="Task_EvaluarViabilidad" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_EvaluarViabilidad" targetRef="Gateway_ClientesViables" />
    <bpmn:sequenceFlow id="Flow_07" name="No" sourceRef="Gateway_ClientesViables" targetRef="Task_AmpliarBusquedaClientes" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Task_AmpliarBusquedaClientes" targetRef="Task_IdentificarClientesPotenciales" />
    <bpmn:sequenceFlow id="Flow_09" name="Sí" sourceRef="Gateway_ClientesViables" targetRef="Task_EstimarCrecimiento" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_EstimarCrecimiento" targetRef="Task_RevisarAnalisis" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_RevisarAnalisis" targetRef="Gateway_AnalisisAprobado" />
    <bpmn:sequenceFlow id="Flow_12" name="No" sourceRef="Gateway_AnalisisAprobado" targetRef="Task_CorregirAnalisis" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_CorregirAnalisis" targetRef="Task_EstimarCrecimiento" />
    <bpmn:sequenceFlow id="Flow_17" name="Sí" sourceRef="Gateway_AnalisisAprobado" targetRef="Task_RegistrarAnalisis" />
    <bpmn:sequenceFlow id="Flow_20" sourceRef="Task_RegistrarAnalisis" targetRef="EndEvent_Aprobado" />
    <bpmn:endEvent id="EndEvent_Aprobado" name="Análisis de cartera aprobado">
      <bpmn:incoming>Flow_20</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_RegistrarAnalisis" name="Registrar análisis de cartera">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:task>
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio del Análisis de cartera">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_EvaluarViabilidad" name="Evaluar viabilidad de clientes">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AnalisisClientesCartera">
    <bpmndi:BPMNPlane id="BPMNPlane_AnalisisClientesCartera" bpmnElement="Collaboration_AnalisisClientesCartera">
