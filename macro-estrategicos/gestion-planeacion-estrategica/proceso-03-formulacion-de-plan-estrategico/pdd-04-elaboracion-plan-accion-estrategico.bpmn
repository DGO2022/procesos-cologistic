<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1_2_3_4" targetNamespace="http://bpmn.io/schema/bpmn" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_1_2_3_4">
    <bpmn:participant id="Participant_1_2_3_4" name="1.2.3.4 Elaboración del plan de acción estratégico" processRef="Process_1_2_3_4" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1_2_3_4" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1_2_3_4">
      <bpmn:lane id="Lane_Subgerencia" name="Subgerencia">
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DesplegarIniciativas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AsignarResponsables</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EstablecerPlazos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConstruirCronograma</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConsolidarPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AjustarRecursos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_PlanAprobado</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_JefesArea" name="Jefes de Área">
        <bpmn:flowNodeRef>Task_DefinirActividades</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IdentificarDependencias</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_GerenciaGeneral" name="Gerencia General">
        <bpmn:flowNodeRef>Task_RevisarViabilidad</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PlanViable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AprobarPlan</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio elaboración del plan">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_DesplegarIniciativas" name="Despliega iniciativas por área">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DefinirActividades" name="Define actividades operativas">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AsignarResponsables" name="Asigna responsables y recursos">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EstablecerPlazos" name="Establece plazos de ejecución">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ConstruirCronograma" name="Construye cronograma maestro">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_IdentificarDependencias" name="Identifica dependencias y riesgos">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ConsolidarPlan" name="Consolida plan de acción">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RevisarViabilidad" name="Revisa viabilidad del plan">
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_PlanViable" name="¿Plan viable?">
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_AjustarRecursos" name="Ajusta recursos, plazos o responsables">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AprobarPlan" name="Aprueba plan de acción">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_DesplegarIniciativas" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_DesplegarIniciativas" targetRef="Task_DefinirActividades" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_DefinirActividades" targetRef="Task_AsignarResponsables" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_AsignarResponsables" targetRef="Task_EstablecerPlazos" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_EstablecerPlazos" targetRef="Task_ConstruirCronograma" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_ConstruirCronograma" targetRef="Task_IdentificarDependencias" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Task_IdentificarDependencias" targetRef="Task_ConsolidarPlan" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Task_ConsolidarPlan" targetRef="Task_RevisarViabilidad" />
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Task_RevisarViabilidad" targetRef="Gateway_PlanViable" />
    <bpmn:sequenceFlow id="Flow_10" name="No" sourceRef="Gateway_PlanViable" targetRef="Task_AjustarRecursos" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_AjustarRecursos" targetRef="Task_ConsolidarPlan" />
    <bpmn:sequenceFlow id="Flow_12" name="Sí" sourceRef="Gateway_PlanViable" targetRef="Task_AprobarPlan" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_AprobarPlan" targetRef="Task_RegistrarPlan" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_RegistrarPlan" targetRef="EndEvent_PlanAprobado" />
    <bpmn:task id="Task_RegistrarPlan" name="Registra plan aprobado">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_PlanAprobado" name="Plan de acción aprobado">
      <bpmn:incoming>Flow_13</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1_2_3_4">
