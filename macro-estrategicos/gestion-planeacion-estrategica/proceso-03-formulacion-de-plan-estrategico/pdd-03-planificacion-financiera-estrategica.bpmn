<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1_2_3_3" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1_2_3_3">
    <bpmn:participant id="Participant_1_2_3_3" name="1.2.3.3 Planificación financiera estratégica" processRef="Process_1_2_3_3" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1_2_3_3" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1_2_3_3">
      <bpmn:lane id="Lane_Subgerencia" name="Subgerencia">
        <bpmn:flowNodeRef>Task_ProyectarIngresos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarPresupuesto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_PresupuestoAprobado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ContadorExterno" name="Contador Externo">
        <bpmn:flowNodeRef>Task_EstimarInversiones</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AnalizarVariablesExternas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ElaborarPresupuesto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnviarPresupuesto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AjustarProyecciones</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_GerenciaGeneral" name="Gerencia General">
        <bpmn:flowNodeRef>Task_EvaluarViabilidad</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PropuestaViable</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AprobarPresupuesto</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:endEvent id="EndEvent_PresupuestoAprobado" name="Presupuesto aprobado">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_ProyectarIngresos" name="Proyecta ingresos por servicio">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EstimarInversiones" name="Estima inversiones estratégicas">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AnalizarVariablesExternas" name="Analiza variables externas">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ElaborarPresupuesto" name="Elabora presupuesto anual">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EnviarPresupuesto" name="Envía presupuesto a Gerencia">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EvaluarViabilidad" name="Evalúa viabilidad del presupuesto">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_PropuestaViable" name="¿Propuesta viable?">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_AjustarProyecciones" name="Ajusta proyecciones financieras">
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AprobarPresupuesto" name="Aprueba presupuesto estratégico">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RegistrarPresupuesto" name="Registra presupuesto aprobado">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_ProyectarIngresos" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_ProyectarIngresos" targetRef="Task_EstimarInversiones" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_EstimarInversiones" targetRef="Task_AnalizarVariablesExternas" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_AnalizarVariablesExternas" targetRef="Task_ElaborarPresupuesto" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_ElaborarPresupuesto" targetRef="Task_EnviarPresupuesto" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_EnviarPresupuesto" targetRef="Task_EvaluarViabilidad" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Task_EvaluarViabilidad" targetRef="Gateway_PropuestaViable" />
    <bpmn:sequenceFlow id="Flow_08" name="No" sourceRef="Gateway_PropuestaViable" targetRef="Task_AjustarProyecciones" />
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Task_AjustarProyecciones" targetRef="Task_ElaborarPresupuesto" />
    <bpmn:sequenceFlow id="Flow_10" name="Sí" sourceRef="Gateway_PropuestaViable" targetRef="Task_AprobarPresupuesto" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_AprobarPresupuesto" targetRef="Task_RegistrarPresupuesto" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_RegistrarPresupuesto" targetRef="EndEvent_PresupuestoAprobado" />
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio planificación financiera">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
  </bpmn:process>
