<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1_2_3_2" targetNamespace="http://bpmn.io/schema/bpmn" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_1_2_3_2">
    <bpmn:participant id="Participant_1_2_3_2" name="1.2.3.2 Diseño del cuadro de mando integral (BSC)" processRef="Process_1_2_3_2" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1_2_3_2" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1_2_3_2">
      <bpmn:lane id="Lane_Subgerencia" name="Subgerencia">
        <bpmn:flowNodeRef>Task_SeleccionarKPIs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DefinirLineaBase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DefinirIniciativas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConsolidarDocumento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AjustarKPIs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarBSC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_BSCAprobado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_JefesArea" name="Jefes de área">
        <bpmn:flowNodeRef>Task_ValidarDatosKPIs</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_GerenciaGeneral" name="Gerencia general">
        <bpmn:flowNodeRef>Task_AsignarResponsables</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_BSCAprobado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarBSC</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:endEvent id="EndEvent_BSCAprobado" name="BSC aprobado">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_SeleccionarKPIs" name="Selecciona KPIs por objetivo">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DefinirLineaBase" name="Define línea base y metas">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ValidarDatosKPIs" name="Valida datos de KPIs">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DefinirIniciativas" name="Define iniciativas por indicador">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AsignarResponsables" name="Asigna responsables de seguimiento">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ConsolidarDocumento" name="Consolida documento BSC">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AjustarKPIs" name="Ajusta KPIs o metas">
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RegistrarBSC" name="Registra BSC aprobado">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_SeleccionarKPIs" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_SeleccionarKPIs" targetRef="Task_DefinirLineaBase" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_DefinirLineaBase" targetRef="Task_ValidarDatosKPIs" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_ValidarDatosKPIs" targetRef="Task_DefinirIniciativas" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_DefinirIniciativas" targetRef="Task_AsignarResponsables" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_AsignarResponsables" targetRef="Task_ConsolidarDocumento" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Task_ConsolidarDocumento" targetRef="Task_RevisarBSC" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Task_RevisarBSC" targetRef="Gateway_BSCAprobado" />
    <bpmn:sequenceFlow id="Flow_09" name="No" sourceRef="Gateway_BSCAprobado" targetRef="Task_AjustarKPIs" />
    <bpmn:sequenceFlow id="Flow_10" name="Sí" sourceRef="Gateway_BSCAprobado" targetRef="Task_RegistrarBSC" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_RegistrarBSC" targetRef="EndEvent_BSCAprobado" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_AjustarKPIs" targetRef="Task_ConsolidarDocumento" />
    <bpmn:exclusiveGateway id="Gateway_BSCAprobado" name="¿BSC aprobado?">
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_RevisarBSC" name="Revisa BSC consolidado">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:task>
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio diseño BSC">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
  </bpmn:process>
