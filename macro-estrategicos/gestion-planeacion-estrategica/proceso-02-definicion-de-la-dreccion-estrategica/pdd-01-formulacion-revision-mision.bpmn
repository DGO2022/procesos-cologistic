<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_FormulacionRevisionMisionVision" targetNamespace="http://bpmn.io/schema/bpmn" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_FormulacionRevisionMisionVision">
    <bpmn:participant id="Participant_FormulacionRevisionMisionVision" name="1.2.2.1 Formulación o revisión de la misión y visión" processRef="Process_FormulacionRevisionMisionVision" />
  </bpmn:collaboration>
  <bpmn:process id="Process_FormulacionRevisionMisionVision" isExecutable="false">
    <bpmn:laneSet id="LaneSet_FormulacionRevisionMisionVision">
      <bpmn:lane id="Lane_Subgerencia" name="Subgerencia">
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarMisionVigente</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RedactarNuevaMision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FormularVisionLargoPlazo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnviarPropuestaLideres</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarMisionVision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AjustarMisionVision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Aprobadas</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ComiteGerencial" name="Comité general">
        <bpmn:flowNodeRef>Task_EvaluarPropuestaEstrategica</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PropuestaConforme</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SocializarMisionVision</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_GerenciaGeneral" name="Gerencia general">
        <bpmn:flowNodeRef>Task_AprobarMedianteActa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MisionVisionAprobadas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ValidarMisionVision</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio de revisión estratégica">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_RevisarMisionVigente" name="Revisar misión vigente">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RedactarNuevaMision" name="Redactar nueva misión">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_FormularVisionLargoPlazo" name="Formular visión de largo plazo">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EnviarPropuestaLideres" name="Enviar propuesta a líderes">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EvaluarPropuestaEstrategica" name="Evaluar propuesta estratégica">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_PropuestaConforme" name="¿Propuesta conforme?">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_RegistrarMisionVision" name="Registrar misión y visión aprobadas">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_RevisarMisionVigente" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_RevisarMisionVigente" targetRef="Task_RedactarNuevaMision" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_RedactarNuevaMision" targetRef="Task_FormularVisionLargoPlazo" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_FormularVisionLargoPlazo" targetRef="Task_EnviarPropuestaLideres" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_EnviarPropuestaLideres" targetRef="Task_SocializarMisionVision" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_SocializarMisionVision" targetRef="Task_EvaluarPropuestaEstrategica" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Task_EvaluarPropuestaEstrategica" targetRef="Gateway_PropuestaConforme" />
    <bpmn:sequenceFlow id="Flow_08" name="No" sourceRef="Gateway_PropuestaConforme" targetRef="Task_AjustarMisionVision" />
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Task_AjustarMisionVision" targetRef="Task_EnviarPropuestaLideres" />
    <bpmn:sequenceFlow id="Flow_10" name="Sí" sourceRef="Gateway_PropuestaConforme" targetRef="Task_ValidarMisionVision" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_ValidarMisionVision" targetRef="Gateway_MisionVisionAprobadas" />
    <bpmn:sequenceFlow id="Flow_12" name="Sí" sourceRef="Gateway_MisionVisionAprobadas" targetRef="Task_AprobarMedianteActa" />
    <bpmn:sequenceFlow id="Flow_15" name="No" sourceRef="Gateway_MisionVisionAprobadas" targetRef="Task_AjustarMisionVision" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Task_AprobarMedianteActa" targetRef="Task_RegistrarMisionVision" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_RegistrarMisionVision" targetRef="EndEvent_Aprobadas" />
    <bpmn:task id="Task_SocializarMisionVision" name="Socializar misión y visión">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AjustarMisionVision" name="Ajustar misión y visión">
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_Aprobadas" name="Misión y visión aprobadas">
      <bpmn:incoming>Flow_18</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_AprobarMedianteActa" name="Aprobar mediante acta">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_MisionVisionAprobadas" name="¿Misión y visión aprobadas?">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ValidarMisionVision" name="Validar misión y visión">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
