  <bpmn:collaboration id="Collaboration_1_2_2_2">
    <bpmn:participant id="Participant_1_2_2_2" name="1.2.2.2 Definición de objetivos estratégicos" processRef="Process_1_2_2_2" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1_2_2_2" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1_2_2_2">
      <bpmn:lane id="Lane_GerenciaGeneral" name="Gerencia general">
        <bpmn:flowNodeRef>Task_PriorizarObjetivos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Aprobados</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AprobarObjetivos</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ComiteGeneral" name="Comité general">
        <bpmn:flowNodeRef>Task_RevisarAlineacion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Alineados</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Subgerencia" name="Subgerencia">
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Aprobado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarFODA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FormularObjetivos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DefinirTecnologicos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DefinirComerciales</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DefinirCertificacion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnviarRevision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AjustarObjetivos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarObjetivos</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio de definición de objetivos">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_Aprobado" name="Objetivos estratégicos aprobados">
      <bpmn:incoming>Flow_19</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_RevisarFODA" name="Revisar FODA aprobado">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_FormularObjetivos" name="Formular objetivos estratégicos">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DefinirTecnologicos" name="Definir objetivos tecnológicos">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DefinirComerciales" name="Definir objetivos comerciales">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_DefinirCertificacion" name="Definir metas de certificación">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EnviarRevision" name="Enviar objetivos para revisión">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RevisarAlineacion" name="Revisar alineación estratégica">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Alineados" name="¿Objetivos alineados?">
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_AjustarObjetivos" name="Ajustar objetivos estratégicos">
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_PriorizarObjetivos" name="Priorizar objetivos estratégicos">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Aprobados" name="¿Objetivos aprobados?">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_AprobarObjetivos" name="Aprobar objetivos estratégicos">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RegistrarObjetivos" name="Registrar objetivos aprobados">
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_RevisarFODA" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="Task_RegistrarObjetivos" targetRef="EndEvent_Aprobado" />
