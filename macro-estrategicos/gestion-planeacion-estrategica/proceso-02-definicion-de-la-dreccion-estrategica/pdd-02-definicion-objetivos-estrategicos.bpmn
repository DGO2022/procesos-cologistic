    <bpmn:sequenceFlow id="Flow_13" name="Sí" sourceRef="Gateway_Aprobados" targetRef="Task_AprobarObjetivos" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_AprobarObjetivos" targetRef="Task_RegistrarObjetivos" />
  </bpmn:process>
