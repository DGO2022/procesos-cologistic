    <bpmn:sequenceFlow id="Flow_11" name="Sí" sourceRef="Gateway_Alineados" targetRef="Task_PriorizarObjetivos" />
    <bpmn:sequenceFlow id="Flow_15" name="No" sourceRef="Gateway_Aprobados" targetRef="Task_AjustarObjetivos" />
