<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1_2_2_4" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1_2_2_4">
    <bpmn:participant id="Participant_1_2_2_4" name="1.2.2.4 Priorización estratégica de iniciativas" processRef="Process_1_2_2_4" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1_2_2_4" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1_2_2_4">
      <bpmn:lane id="Lane_Subgerencia" name="Subgerencia">
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ListarIniciativas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EvaluarImpacto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ClasificarIniciativas</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Gerente" name="Gerente">
        <bpmn:flowNodeRef>Task_RevisarPortafolio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Aprobado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PortafolioAprobado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AprobarPortafolio</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio de priorización estratégica">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_Aprobado" name="Portafolio aprobado">
      <bpmn:incoming>Flow_08</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_ListarIniciativas" name="Listar iniciativas estratégicas">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_EvaluarImpacto" name="Evaluar impacto, viabilidad y urgencia">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ClasificarIniciativas" name="Clasificar iniciativas por horizonte temporal">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RevisarPortafolio" name="Revisar portafolio priorizado">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_ListarIniciativas" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_ListarIniciativas" targetRef="Task_EvaluarImpacto" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_EvaluarImpacto" targetRef="Task_ClasificarIniciativas" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_ClasificarIniciativas" targetRef="Task_RevisarPortafolio" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_RevisarPortafolio" targetRef="Gateway_PortafolioAprobado" />
    <bpmn:sequenceFlow id="Flow_06" name="No" sourceRef="Gateway_PortafolioAprobado" targetRef="Task_EvaluarImpacto" />
    <bpmn:sequenceFlow id="Flow_07" name="Sí" sourceRef="Gateway_PortafolioAprobado" targetRef="Task_AprobarPortafolio" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Task_AprobarPortafolio" targetRef="EndEvent_Aprobado" />
    <bpmn:exclusiveGateway id="Gateway_PortafolioAprobado" name="¿Portafolio aprobado?">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_AprobarPortafolio" name="Aprobar portafolio">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1_2_2_4">
    <bpmndi:BPMNPlane id="BPMNPlane_1_2_2_4" bpmnElement="Collaboration_1_2_2_4">
      <bpmndi:BPMNShape id="Participant_1_2_2_4_di" bpmnElement="Participant_1_2_2_4" isHorizontal="true">
        <dc:Bounds x="60" y="40" width="1280" height="720" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Gerente_di" bpmnElement="Lane_Gerente" isHorizontal="true">
        <dc:Bounds x="90" y="400" width="1250" height="360" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Subgerencia_di" bpmnElement="Lane_Subgerencia" isHorizontal="true">
        <dc:Bounds x="90" y="40" width="1250" height="360" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Inicio_di" bpmnElement="StartEvent_Inicio">
        <dc:Bounds x="210" y="140" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="160" y="190" width="140" height="45" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Aprobado_di" bpmnElement="EndEvent_Aprobado">
        <dc:Bounds x="900" y="545" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="860" y="595" width="120" height="30" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ListarIniciativas_di" bpmnElement="Task_ListarIniciativas">
        <dc:Bounds x="360" y="115" width="150" height="90" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EvaluarImpacto_di" bpmnElement="Task_EvaluarImpacto">
        <dc:Bounds x="640" y="115" width="160" height="90" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ClasificarIniciativas_di" bpmnElement="Task_ClasificarIniciativas">
        <dc:Bounds x="910" y="115" width="160" height="90" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RevisarPortafolio_di" bpmnElement="Task_RevisarPortafolio">
        <dc:Bounds x="170" y="520" width="160" height="90" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PortafolioAprobado_di" bpmnElement="Gateway_PortafolioAprobado" isMarkerVisible="true">
        <dc:Bounds x="450" y="533" width="60" height="60" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="458" y="603" width="54" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AprobarPortafolio_di" bpmnElement="Task_AprobarPortafolio">
        <dc:Bounds x="650" y="518" width="160" height="90" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_01_di" bpmnElement="Flow_01">
        <di:waypoint x="246" y="158" />
        <di:waypoint x="360" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_02_di" bpmnElement="Flow_02">
        <di:waypoint x="510" y="160" />
        <di:waypoint x="640" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_03_di" bpmnElement="Flow_03">
        <di:waypoint x="800" y="160" />
        <di:waypoint x="910" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_04_di" bpmnElement="Flow_04">
        <di:waypoint x="990" y="205" />
        <di:waypoint x="990" y="345" />
        <di:waypoint x="250" y="345" />
        <di:waypoint x="250" y="520" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_05_di" bpmnElement="Flow_05">
        <di:waypoint x="330" y="563" />
        <di:waypoint x="451" y="564" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_06_di" bpmnElement="Flow_06">
        <di:waypoint x="480" y="533" />
        <di:waypoint x="480" y="450" />
        <di:waypoint x="720" y="450" />
        <di:waypoint x="720" y="205" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="525" y="455" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_07_di" bpmnElement="Flow_07">
        <di:waypoint x="509" y="564" />
        <di:waypoint x="650" y="564" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="576" y="542" width="11" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_08_di" bpmnElement="Flow_08">
        <di:waypoint x="810" y="565" />
        <di:waypoint x="855" y="565" />
        <di:waypoint x="855" y="563" />
        <di:waypoint x="900" y="563" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
