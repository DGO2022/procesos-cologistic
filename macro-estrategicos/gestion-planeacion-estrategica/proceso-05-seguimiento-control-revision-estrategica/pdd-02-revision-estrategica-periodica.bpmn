<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1_2_5_2" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1_2_5_2">
    <bpmn:participant id="Participant_1_2_5_2" name="1.2.5.2 Revisión estratégica periódica" processRef="Process_1_2_5_2" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1_2_5_2" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1_2_5_2">
      <bpmn:lane id="Lane_Gerente" name="Gerente">
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConvocarReunion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AnalizarImpacto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_RequiereAjustes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DecidirAjustes</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Subgerencia" name="Subgerencia">
        <bpmn:flowNodeRef>EndEvent_RevisionRegistrada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PresentarReporte</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegistrarAcuerdos</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio de revisión estratégica">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_RevisionRegistrada" name="Revisión estratégica registrada">
      <bpmn:incoming>Flow_08</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_ConvocarReunion" name="Convoca reunión de revisión estratégica">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_PresentarReporte" name="Presenta reporte de avance de KPIs e iniciativas">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_AnalizarImpacto" name="Analiza impacto de cambios del entorno sobre la estrategia">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_RequiereAjustes" name="¿Se requieren ajustes al plan estratégico?">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_DecidirAjustes" name="Decide ajustes al plan">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RegistrarAcuerdos" name="Registrar acuerdos y compromisos en acta de revisión estratégica">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_ConvocarReunion" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_ConvocarReunion" targetRef="Task_PresentarReporte" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_PresentarReporte" targetRef="Task_AnalizarImpacto" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_AnalizarImpacto" targetRef="Gateway_RequiereAjustes" />
    <bpmn:sequenceFlow id="Flow_05" name="No" sourceRef="Gateway_RequiereAjustes" targetRef="Task_DecidirAjustes" />
    <bpmn:sequenceFlow id="Flow_06" name="Sí" sourceRef="Gateway_RequiereAjustes" targetRef="Task_RegistrarAcuerdos" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Task_DecidirAjustes" targetRef="Task_RegistrarAcuerdos" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Task_RegistrarAcuerdos" targetRef="EndEvent_RevisionRegistrada" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1_2_5_2">
    <bpmndi:BPMNPlane id="BPMNPlane_1_2_5_2" bpmnElement="Collaboration_1_2_5_2">
      <bpmndi:BPMNShape id="Participant_1_2_5_2_di" bpmnElement="Participant_1_2_5_2" isHorizontal="true">
        <dc:Bounds x="10" y="20" width="1230" height="390" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Subgerencia_di" bpmnElement="Lane_Subgerencia" isHorizontal="true">
        <dc:Bounds x="40" y="210" width="1200" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Gerente_di" bpmnElement="Lane_Gerente" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="1200" height="190" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Inicio_di" bpmnElement="StartEvent_Inicio">
        <dc:Bounds x="120" y="80" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RevisionRegistrada_di" bpmnElement="EndEvent_RevisionRegistrada">
        <dc:Bounds x="1080" y="305" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ConvocarReunion_di" bpmnElement="Task_ConvocarReunion">
        <dc:Bounds x="205" y="55" width="95" height="65" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PresentarReporte_di" bpmnElement="Task_PresentarReporte">
        <dc:Bounds x="390" y="245" width="105" height="65" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AnalizarImpacto_di" bpmnElement="Task_AnalizarImpacto">
        <dc:Bounds x="580" y="80" width="105" height="65" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_RequiereAjustes_di" bpmnElement="Gateway_RequiereAjustes" isMarkerVisible="true">
        <dc:Bounds x="740" y="88" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="700" y="35" width="150" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DecidirAjustes_di" bpmnElement="Task_DecidirAjustes">
        <dc:Bounds x="895" y="80" width="95" height="65" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RegistrarAcuerdos_di" bpmnElement="Task_RegistrarAcuerdos">
        <dc:Bounds x="860" y="285" width="145" height="75" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_01_di" bpmnElement="Flow_01">
        <di:waypoint x="156" y="98" />
        <di:waypoint x="205" y="88" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_02_di" bpmnElement="Flow_02">
        <di:waypoint x="300" y="88" />
        <di:waypoint x="350" y="88" />
        <di:waypoint x="350" y="278" />
        <di:waypoint x="390" y="278" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_03_di" bpmnElement="Flow_03">
        <di:waypoint x="495" y="278" />
        <di:waypoint x="540" y="278" />
        <di:waypoint x="540" y="113" />
        <di:waypoint x="580" y="113" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_04_di" bpmnElement="Flow_04">
        <di:waypoint x="685" y="113" />
        <di:waypoint x="740" y="113" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_05_di" bpmnElement="Flow_05">
        <di:waypoint x="790" y="113" />
        <di:waypoint x="895" y="113" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="830" y="90" width="25" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_06_di" bpmnElement="Flow_06">
        <di:waypoint x="765" y="138" />
        <di:waypoint x="765" y="322" />
        <di:waypoint x="860" y="322" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="775" y="190" width="25" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_07_di" bpmnElement="Flow_07">
        <di:waypoint x="942" y="145" />
        <di:waypoint x="942" y="285" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_08_di" bpmnElement="Flow_08">
        <di:waypoint x="1005" y="322" />
        <di:waypoint x="1080" y="323" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
