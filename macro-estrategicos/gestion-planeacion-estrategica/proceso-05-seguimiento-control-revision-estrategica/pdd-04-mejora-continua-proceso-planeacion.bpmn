<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1_2_5_4" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1_2_5_4">
    <bpmn:participant id="Participant_1_2_5_4" name="1.2.5.4 Mejora continua del proceso de planeación" processRef="Process_1_2_5_4" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1_2_5_4" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1_2_5_4">
      <bpmn:lane id="Lane_Subgerencia" name="Subgerencia">
        <bpmn:flowNodeRef>Task_EvaluarEfectividad</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RecopilarLecciones</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ProponerMejoras</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AjustarPropuesta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ActualizarDocumentos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IniciarNuevoCiclo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_NuevoCiclo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Gerencia" name="Gerencia">
        <bpmn:flowNodeRef>Task_RevisarMejoras</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_MejorasAprobadas</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:endEvent id="EndEvent_NuevoCiclo" name="Nuevo ciclo de planeación iniciado">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_EvaluarEfectividad" name="Evalúa efectividad del ciclo">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RecopilarLecciones" name="Recopila lecciones aprendidas">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ProponerMejoras" name="Propone mejoras al proceso">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RevisarMejoras" name="Revisa mejoras propuestas">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_MejorasAprobadas" name="¿Mejoras aprobadas?">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_AjustarPropuesta" name="Ajusta propuesta de mejora">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ActualizarDocumentos" name="Actualiza documentos del proceso">
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_IniciarNuevoCiclo" name="Inicia nuevo ciclo de planeación">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Inicio" targetRef="Task_EvaluarEfectividad" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_EvaluarEfectividad" targetRef="Task_RecopilarLecciones" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_RecopilarLecciones" targetRef="Task_ProponerMejoras" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_ProponerMejoras" targetRef="Task_RevisarMejoras" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_RevisarMejoras" targetRef="Gateway_MejorasAprobadas" />
    <bpmn:sequenceFlow id="Flow_06" name="No" sourceRef="Gateway_MejorasAprobadas" targetRef="Task_AjustarPropuesta" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Task_AjustarPropuesta" targetRef="Task_ProponerMejoras" />
    <bpmn:sequenceFlow id="Flow_09" name="Sí" sourceRef="Gateway_MejorasAprobadas" targetRef="Task_ActualizarDocumentos" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_ActualizarDocumentos" targetRef="Task_IniciarNuevoCiclo" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_IniciarNuevoCiclo" targetRef="EndEvent_NuevoCiclo" />
    <bpmn:startEvent id="StartEvent_Inicio" name="Inicio de mejora continua">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1_2_5_4">
    <bpmndi:BPMNPlane id="BPMNPlane_1_2_5_4" bpmnElement="Collaboration_1_2_5_4">
      <bpmndi:BPMNShape id="Participant_1_2_5_4_di" bpmnElement="Participant_1_2_5_4" isHorizontal="true">
        <dc:Bounds x="40" y="20" width="1550" height="390" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Gerencia_di" bpmnElement="Lane_Gerencia" isHorizontal="true">
        <dc:Bounds x="70" y="210" width="1520" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Subgerencia_di" bpmnElement="Lane_Subgerencia" isHorizontal="true">
        <dc:Bounds x="70" y="20" width="1520" height="190" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NuevoCiclo_di" bpmnElement="EndEvent_NuevoCiclo">
        <dc:Bounds x="1445" y="112" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EvaluarEfectividad_di" bpmnElement="Task_EvaluarEfectividad">
        <dc:Bounds x="210" y="50" width="95" height="65" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecopilarLecciones_di" bpmnElement="Task_RecopilarLecciones">
        <dc:Bounds x="360" y="50" width="95" height="65" />
