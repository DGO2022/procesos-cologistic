      <bpmndi:BPMNShape id="Task_ProponerMejoras_di" bpmnElement="Task_ProponerMejoras">
        <dc:Bounds x="510" y="50" width="95" height="65" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RevisarMejoras_di" bpmnElement="Task_RevisarMejoras">
        <dc:Bounds x="650" y="265" width="95" height="65" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_MejorasAprobadas_di" bpmnElement="Gateway_MejorasAprobadas" isMarkerVisible="true">
        <dc:Bounds x="810" y="272" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="775" y="325" width="130" height="30" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AjustarPropuesta_di" bpmnElement="Task_AjustarPropuesta">
        <dc:Bounds x="900" y="80" width="95" height="65" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ActualizarDocumentos_di" bpmnElement="Task_ActualizarDocumentos">
        <dc:Bounds x="1150" y="95" width="95" height="65" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IniciarNuevoCiclo_di" bpmnElement="Task_IniciarNuevoCiclo">
        <dc:Bounds x="1300" y="95" width="95" height="65" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Inicio_di" bpmnElement="StartEvent_Inicio">
        <dc:Bounds x="130" y="65" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="109" y="101" width="78" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
